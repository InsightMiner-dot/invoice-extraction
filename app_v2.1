        if ff: dv = dv[dv["file_name"].isin(ff)]
        if fm: dv = dv[dv["extraction_mode"].isin(fm)]
        if fq: dv = dv[dv["⚠️"]=="⚠️"]

        st.caption(f"{len(dv)} rows")

        def hl(row):
            if row.get("⚠️")=="⚠️":            return ["background-color:#fff3cd"]*len(row)
            if str(row.get("row_type","")).startswith("charge"): return ["background-color:#dbeafe"]*len(row)
            if row.get("row_type") in ("subtotal","total"):      return ["background-color:#dcfce7"]*len(row)
            return [""]*len(row)

        st.dataframe(dv.style.apply(hl,axis=1), use_container_width=True, height=500, hide_index=True)

        # Downloads
        d1,d2 = st.columns(2)
        d1.download_button(
            "⬇️ Download CSV",
            df.drop(columns=["⚠️"],errors="ignore").to_csv(index=False).encode("utf-8-sig"),
            file_name=f"invoices_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv",
            mime="text/csv", use_container_width=True
        )
        d2.download_button(
            "⬇️ Download Filtered CSV",
            dv.drop(columns=["⚠️"],errors="ignore").to_csv(index=False).encode("utf-8-sig"),
            file_name=f"invoices_filtered_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv",
            mime="text/csv", use_container_width=True
        )

        with st.expander("Raw JSON per file", expanded=False):
            for fname, ext in st.session_state.all_extracted.items():
                with st.expander(fname):
                    st.json(ext)
                    st.download_button(f"JSON — {fname}", json.dumps(ext,indent=2),
                        f"{fname}.json","application/json", key=f"jdl_{fname}")

# ════════════════════════════════════════════════════════
# TAB 5 — Mapping
# ════════════════════════════════════════════════════════
with t5:
    rename = dict(st.session_state.col_rename)

    # Load vendor
    reg = load_registry()
    if reg:
        sel = st.selectbox("Load vendor mapping", [""]+list(reg.keys()))
        if sel:
            saved = reg.get(sel,{}).get("col_rename",{})
            if saved: rename = saved

    st.divider()
    st.caption("Rename output CSV columns (optional)")

    ALL_STD = [
        "supplier_name","supplier_id","supplier_address",
        "invoice_number","invoice_date",
        "customer_name","customer_address",
        "remit_to","shipper_address","bill_to",
        "origin","destination",
        "item_number","manifest","description",
        "quantity","unit_of_measurement","rate","amount"
    ]

    new_rename = {}
    for i in range(0, len(ALL_STD), 2):
        c1,c2 = st.columns(2)
        for j,std in enumerate(ALL_STD[i:i+2]):
            col = c1 if j==0 else c2
            val = col.text_input(std, value=rename.get(std,""), placeholder=std, key=f"r_{std}")
            if val.strip(): new_rename[std] = val.strip()

    st.divider()
    vname = st.text_input("Save for vendor", placeholder="optional")
    s1,s2 = st.columns(2)
    if s1.button("Save", use_container_width=True):
        st.session_state.col_rename = new_rename
        if vname.strip():
            r = load_registry()
            r.setdefault(vname.strip(),{})["col_rename"] = new_rename
            save_registry(r)
        st.toast("Saved")
    if s2.button("Reset", use_container_width=True):
        st.session_state.col_rename = {}
        st.rerun()
