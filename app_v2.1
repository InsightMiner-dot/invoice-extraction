# ── Helpers ───────────────────────────────────────────────────────────────────

def load_keywords():
    if os.path.exists(KEYWORDS_FILE):
        with open(KEYWORDS_FILE) as f:
            return json.load(f).get("keywords", list(DEFAULT_KEYWORDS))
    return list(DEFAULT_KEYWORDS)

def save_keywords(kws):
    with open(KEYWORDS_FILE, "w") as f:
        json.dump({"keywords": kws}, f, indent=2)

def get_llm_client():
    return AzureOpenAI(
        azure_endpoint=AZURE_OPENAI_ENDPOINT,
        api_key=AZURE_OPENAI_KEY,
        api_version=AZURE_OPENAI_API_VERSION,
    )

def to_float(v):
    if v is None:
        return None
    try:
        return float(re.sub(r"[^\d.\-]", "", str(v)))
    except Exception:
        return None

def is_charge(text: str, keywords: list) -> bool:
    t = str(text).lower()
    return any(kw.lower() in t for kw in keywords)

# ── Azure DI — same for both modes ───────────────────────────────────────────

def run_azure_di(file_bytes: bytes) -> dict:
    client = DocumentIntelligenceClient(DI_ENDPOINT, AzureKeyCredential(DI_KEY))
    poller = client.begin_analyze_document(
        "prebuilt-layout",
        body=file_bytes,
        content_type="application/octet-stream"
    )
    result = poller.result()

    output = {
        "raw_text":      result.content or "",
        "header_fields": {},
        "tables":        []
    }

    if result.key_value_pairs:
        for kv in result.key_value_pairs:
            if kv.key and kv.value:
                output["header_fields"][kv.key.content.strip()] = {
                    "value":      kv.value.content.strip(),
                    "confidence": round(kv.confidence or 0, 3)
                }

    if result.tables:
        for t_idx, table in enumerate(result.tables):
            headers, row_map = {}, {}
            page_num = 1
            for cell in table.cells:
                if cell.bounding_regions:
                    page_num = cell.bounding_regions[0].page_number
                if cell.row_index == 0:
                    headers[cell.column_index] = cell.content.strip()
                else:
                    r = cell.row_index
                    if r not in row_map:
                        row_map[r] = {}
                    col = headers.get(cell.column_index, f"col_{cell.column_index}")
                    row_map[r][col] = cell.content.strip()

            output["tables"].append({
                "table_index": t_idx,
                "headers":     list(headers.values()),
                "rows":        [row_map[k] for k in sorted(row_map.keys())],
                "page_number": page_num
            })

    return output

# ── DI-only extraction — take ALL fields as-is, repeat per row ───────────────

INVOICE_START_HINTS = [
    "invoice no","invoice number","inv no","inv #","invoice #","bill no","bill number"
]

def extract_di_only(di_output: dict, charge_keywords: list) -> dict:
    """
    Takes ALL DI header key-value pairs exactly as-is — no forced label mapping.
    Whatever DI labels (Recipient, Ship-To, Vendor, From etc.) are kept verbatim.
    Header fields repeat on every row until a new invoice is detected.
    All table columns kept as-is — no renaming.
    """

    # All header fields exactly as DI found them
    all_header_fields = {
        k: v["value"]
        for k, v in di_output.get("header_fields", {}).items()
        if v.get("value")
    }

    # Best-effort: detect invoice number and date by loose keyword match
    inv_number = None
    inv_date   = None
    subtotal   = None
    total_amt  = None
    for k, v in di_output.get("header_fields", {}).items():
        kl = k.lower()
        if inv_number is None and any(h in kl for h in ["invoice no","invoice number","inv no","inv #","bill no"]):
            inv_number = v["value"]
        if inv_date is None and any(h in kl for h in ["invoice date","date","dated","bill date"]):
            inv_date = v["value"]
        if subtotal is None and any(h in kl for h in ["subtotal","sub total","net amount","taxable amount"]):
            subtotal = v["value"]
        if total_amt is None and any(h in kl for h in ["grand total","total amount","invoice total","amount due","net payable"]):
            total_amt = v["value"]
        # fallback for plain "total" but only if not already found
        if total_amt is None and kl.strip() == "total":
            total_amt = v["value"]

    line_items   = []
    charge_lines = []

    for table in di_output.get("tables", []):
        headers  = table.get("headers", [])
        page_num = table.get("page_number", 1)
        # active header snapshot — starts as all DI header fields
        active_snap = dict(all_header_fields)

        for row in table.get("rows", []):
            row_vals = [str(v) for v in row.values() if v]
            row_text = " ".join(row_vals)
            row_lower = row_text.lower()

            # Detect if this row signals a new invoice starting
            if any(hint in row_lower for hint in INVOICE_START_HINTS) and len(row_vals) <= 3:
                # Likely a header repeat row — update snapshot and skip
                for col_name, val in row.items():
                    if val:
                        active_snap[col_name] = val
                continue

            # Detect charge row
            if is_charge(row_text, charge_keywords):
                amt_val = None
                for v in reversed(list(row.values())):
                    if v and to_float(v) is not None:
                        amt_val = v
                        break
                desc_val = next((v for v in row.values() if v and to_float(v) is None), row_text[:80])
                charge_lines.append({
                    "description":      desc_val,
                    "charge_type":      "charge",
                    "amount":           amt_val,
                    "page_number":      page_num,
                    "_header_snapshot": dict(active_snap)
                })
                continue

            # Regular line item — keep ALL columns as-is in extra_columns
            # Also try soft-match for QC fields (qty, rate, amount)
            item = {
                "page_number":         page_num,
                "_header_snapshot":    dict(active_snap),
                "item_number":         None,
                "manifest":            None,
                "description":         None,
                "quantity":            None,
                "unit_of_measurement": None,
                "rate":                None,
                "amount":              None,
                "extra_columns":       {k: v for k, v in row.items() if v}
            }
            for col_name, val in row.items():
                if not val:
                    continue
                cl = col_name.lower()
                if any(h in cl for h in COL_HINTS.get("item_number",[])):
                    item["item_number"] = val
                elif any(h in cl for h in COL_HINTS.get("manifest",[])):
                    item["manifest"] = val
                elif any(h in cl for h in COL_HINTS.get("description",[])):
                    item["description"] = val
                elif any(h in cl for h in COL_HINTS.get("quantity",[])):
                    item["quantity"] = val
                elif any(h in cl for h in COL_HINTS.get("unit_of_measurement",[])):
                    item["unit_of_measurement"] = val
                elif any(h in cl for h in COL_HINTS.get("rate",[])):
                    item["rate"] = val
                elif any(h in cl for h in COL_HINTS.get("amount",[])):
                    item["amount"] = val

            # If description still not found — first non-numeric value
            if not item["description"]:
                item["description"] = next(
                    (v for v in row.values() if v and to_float(v) is None), None
                )

            line_items.append(item)

    return {
        "invoice_number":     inv_number,
        "invoice_date":       inv_date,
        "subtotal":           subtotal,
        "total_amount":       total_amt,
        "all_header_fields":  all_header_fields,
        "line_items":         line_items,
        "charge_lines":       charge_lines,
        "unmapped_header_fields": {}
    }


def build_tabular_rows_di_only(filename: str, extracted: dict, mode: str) -> list:
    """
    DI-only flat row builder.
    Every row gets ALL DI header fields as columns (prefixed hdr_).
    All original table columns appear on the right as extra columns.
    Same output structure as build_tabular_rows() so Tab 4 works identically.
    """
    rows    = []
    all_hf  = extracted.get("all_header_fields", {})

    def base_row(snap):
        r = {
            "file_name":       filename,
            "extraction_mode": mode,
            "invoice_number":  extracted.get("invoice_number"),
            "invoice_date":    extracted.get("invoice_date"),
        }
        # Add all DI header fields as columns — label exactly as DI found them
        for k, v in snap.items():
            r[k] = v
        return r

    for item in (extracted.get("line_items") or []):
        snap = item.get("_header_snapshot", all_hf)
        row  = base_row(snap)
        row.update({
            "page_number":         item.get("page_number", ""),
            "item_number":         item.get("item_number"),
            "manifest":            item.get("manifest"),
            "description":         item.get("description"),
            "quantity":            item.get("quantity"),
            "unit_of_measurement": item.get("unit_of_measurement"),
            "rate":                item.get("rate"),
            "amount":              item.get("amount"),
            "subtotal":            None,
            "total":               None,
            "row_type":            "line_item"
        })
        for k, v in (item.get("extra_columns") or {}).items():
            row[k] = v
        rows.append(row)

    for charge in (extracted.get("charge_lines") or []):
        snap = charge.get("_header_snapshot", all_hf)
        row  = base_row(snap)
        row.update({
            "page_number":         charge.get("page_number", ""),
            "item_number":         None,
            "manifest":            None,
            "description":         charge.get("description"),
            "quantity":            None,
            "unit_of_measurement": None,
            "rate":                None,
            "amount":              charge.get("amount"),
            "subtotal":            None,
            "total":               None,
            "row_type":            f"charge:{charge.get('charge_type','other')}"
        })
        rows.append(row)

    if extracted.get("subtotal"):
        row = base_row(all_hf)
        row.update({"description":"SUBTOTAL","subtotal":extracted["subtotal"],
                    "total":None,"row_type":"subtotal",
                    "page_number":"","item_number":None,"manifest":None,
                    "quantity":None,"unit_of_measurement":None,"rate":None,"amount":None})
        rows.append(row)

    if extracted.get("total_amount"):
        row = base_row(all_hf)
        row.update({"description":"TOTAL","subtotal":None,
                    "total":extracted["total_amount"],"row_type":"total",
                    "page_number":"","item_number":None,"manifest":None,
                    "quantity":None,"unit_of_measurement":None,"rate":None,"amount":None})
        rows.append(row)

    return rows


# ── LLM extraction — unchanged ────────────────────────────────────────────────

def extract_with_llm(di_output: dict, charge_keywords: list) -> dict:
    prompt = f"""
You are an invoice data extraction assistant.

=== NUMBER RULES (ABSOLUTE) ===
- Copy ALL numeric values EXACTLY as they appear — do NOT fix, round, or change any number
- Do NOT calculate any missing number — return null if missing

=== EXTRACTION RULES ===
- Map fields by meaning regardless of label name
- supplier = vendor / seller / from / shipper / issued by / service provider
- customer = bill to / sold to / buyer / client / consignee / recipient / deliver to / attention / party name
- customer_address = billing address / delivery address / sold to address / recipient address
- remit_to = remit to / pay to / remittance / remit payment
- shipper_address = ship from / dispatch from / generator address / generator name / pickup address
- bill_to = billing address / sold to / sold to address / invoice to / charge to
- origin = ship from / port of loading / POL / loading port / generator / generated at / place of supply / pickup location / from location
- destination = ship to / port of discharge / POD / delivery port / deliver to / final destination / consignee location / delivery location
- charge_keywords: {charge_keywords}
- Rows matching charge_keywords → add to charge_lines array
- Include page_number per row (default 1)
- Extra table columns not in standard → extra_columns dict per row
- Return ONLY valid JSON, no explanation, no markdown

DI RAW OUTPUT:
{json.dumps(di_output, indent=2)}

Return EXACTLY this structure (null for missing):
{{
  "supplier_name": null, "supplier_id": null, "supplier_address": null,
  "invoice_number": null, "invoice_date": null,
  "customer_name": null, "customer_address": null,
  "remit_to": null, "shipper_address": null, "bill_to": null,
  "origin": null, "destination": null,
  "subtotal": null, "total_amount": null,
  "line_items": [{{
    "page_number": 1, "item_number": null, "manifest": null,
    "description": null, "quantity": null, "unit_of_measurement": null,
    "rate": null, "amount": null, "extra_columns": {{}}
  }}],
  "charge_lines": [{{
    "description": null, "charge_type": null, "amount": null, "page_number": null
  }}],
  "unmapped_header_fields": {{}}
}}
"""
    response = get_llm_client().chat.completions.create(
        model=AZURE_OPENAI_DEPLOYMENT,
        messages=[
            {"role": "system", "content": "Extract invoice data. Never modify numbers. Return only valid JSON."},
            {"role": "user",   "content": prompt}
        ],
        max_tokens=3000,
        temperature=0
    )
    raw = re.sub(r"```json|```", "", response.choices[0].message.content.strip()).strip()
    return json.loads(raw)

# ── Build flat rows — identical for both modes ────────────────────────────────

def build_tabular_rows(filename: str, extracted: dict, mode: str) -> list:
    """
    Same function used for both DI-only and DI+LLM.
    Header columns repeat on every row.
    Charge lines become rows in description column.
    Subtotal and Total become their own rows.
    """
    rows = []

    header = {
        "file_name":        filename,
        "extraction_mode":  mode,
        "supplier_name":    extracted.get("supplier_name"),
        "supplier_id":      extracted.get("supplier_id"),
        "supplier_address": extracted.get("supplier_address"),
        "invoice_number":   extracted.get("invoice_number"),
        "invoice_date":     extracted.get("invoice_date"),
        "customer_name":    extracted.get("customer_name"),
        "customer_address": extracted.get("customer_address"),
        "remit_to":         extracted.get("remit_to"),
        "shipper_address":  extracted.get("shipper_address"),
        "bill_to":          extracted.get("bill_to"),
        "origin":           extracted.get("origin"),
        "destination":      extracted.get("destination"),
    }

    # Line item rows
    for item in (extracted.get("line_items") or []):
        row = dict(header)
        row.update({
            "page_number":         item.get("page_number", 1),
            "item_number":         item.get("item_number"),
            "manifest":            item.get("manifest"),
            "description":         item.get("description"),
            "quantity":            item.get("quantity"),
            "unit_of_measurement": item.get("unit_of_measurement"),
            "rate":                item.get("rate"),
            "amount":              item.get("amount"),
            "subtotal":            None,
            "total":               None,
            "row_type":            "line_item"
        })
        for k, v in (item.get("extra_columns") or {}).items():
            row[k] = v
        rows.append(row)

    # Charge rows — appear as line items, description = charge name
    for charge in (extracted.get("charge_lines") or []):
        row = dict(header)
        row.update({
            "page_number":         charge.get("page_number", ""),
            "item_number":         None,
            "manifest":            None,
            "description":         charge.get("description"),
            "quantity":            None,
            "unit_of_measurement": None,
            "rate":                None,
            "amount":              charge.get("amount"),
            "subtotal":            None,
            "total":               None,
            "row_type":            f"charge:{charge.get('charge_type','other')}"
        })
        rows.append(row)

    # Subtotal row
    if extracted.get("subtotal"):
        row = dict(header)
        row.update({
            "page_number": "", "item_number": None, "manifest": None,
            "description": "SUBTOTAL", "quantity": None,
            "unit_of_measurement": None, "rate": None, "amount": None,
            "subtotal": extracted.get("subtotal"), "total": None,
            "row_type": "subtotal"
        })
        rows.append(row)

    # Total row
    if extracted.get("total_amount"):
        row = dict(header)
        row.update({
            "page_number": "", "item_number": None, "manifest": None,
            "description": "TOTAL", "quantity": None,
            "unit_of_measurement": None, "rate": None, "amount": None,
            "subtotal": None, "total": extracted.get("total_amount"),
            "row_type": "total"
        })
        rows.append(row)

    return rows

# ── QC ────────────────────────────────────────────────────────────────────────

def run_qc(rows: list, extracted: dict) -> dict:
    issues       = {}
    total_amount = to_float(extracted.get("total_amount"))
    line_sum     = 0.0

    for i, row in enumerate(rows):
        if row.get("row_type") in ("subtotal", "total"):
            continue
        amt = to_float(row.get("amount"))
        if amt is not None:
            line_sum += amt

        qty  = to_float(row.get("quantity"))
        rate = to_float(row.get("rate"))
        if qty is not None and rate is not None and amt is not None:
            expected = round(qty * rate, 2)
            if abs(expected - round(amt, 2)) > 0.02:
                issues[i] = f"Qty×Rate={qty}×{rate}={expected} ≠ amount={amt}"

    total_issue = None
    if total_amount and abs(line_sum - total_amount) > 0.5:
        total_issue = (
            f"Sum of amounts ({line_sum:.2f}) ≠ invoice total ({total_amount:.2f})"
        )

    return {"row_issues": issues, "total_issue": total_issue, "line_sum": line_sum}

