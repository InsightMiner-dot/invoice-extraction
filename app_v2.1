# TAB 3 — DI + LLM
# ════════════════════════════════════════════════════════
with tab3:
    st.subheader("DI + LLM Extraction")
    st.caption(
        "Azure DI extracts raw structure → GPT-4o mini maps and normalises all fields. "
        "Handles any layout, any vendor, scanned PDFs."
    )

    llm_files = [f for f in st.session_state.files_info if f["mode"] == "DI + LLM"]

    if not llm_files:
        st.info("No files assigned to DI + LLM. Go to Tab 1 to upload and assign.")
    else:
        pending = [f for f in llm_files if f["name"] not in st.session_state.processed]
        done    = [f for f in llm_files if f["name"] in st.session_state.processed]

        m1, m2 = st.columns(2)
        m1.metric("Pending", len(pending))
        m2.metric("Done",    len(done))

        if done:
            st.success("Already processed: " + ", ".join(f["name"] for f in done))

        if pending:
            st.markdown("**Files to process:**")
            for f in pending:
                st.markdown(f"- 📄 {f['name']}")

            if st.button("🚀 Run DI + LLM — All Pending", type="primary", use_container_width=True):
                charge_keywords = st.session_state.charge_keywords
                progress = st.progress(0, text="Starting...")
                errors   = []

                for idx, fi in enumerate(pending):
                    progress.progress(idx / len(pending), text=f"Processing {fi['name']}...")
                    try:
                        with st.spinner(f"🔍 Azure DI: {fi['name']}"):
                            di_out = run_azure_di(fi["bytes"])

                        with st.spinner(f"🤖 LLM: {fi['name']}"):
                            extracted = extract_with_llm(di_out, charge_keywords)

                        rows = build_tabular_rows(fi["name"], extracted, "DI + LLM")
                        qc   = run_qc(rows, extracted)

                        st.session_state.all_extracted[fi["name"]] = extracted
                        st.session_state.all_rows.extend(rows)
                        st.session_state.qc_results[fi["name"]]    = qc
                        st.session_state.processed.add(fi["name"])

                        n_items   = len(extracted.get("line_items") or [])
                        n_charges = len(extracted.get("charge_lines") or [])
                        st.success(
                            f"✅ {fi['name']} — "
                            f"{n_items} line items, {n_charges} charge rows, "
                            f"{len(rows)} total rows"
                        )

                    except Exception as e:
                        errors.append(f"{fi['name']}: {e}")
                        st.error(f"❌ {fi['name']}: {e}")

                progress.progress(1.0, text="Done!")
                if not errors:
                    st.success("All done → go to Tab 4 for results")

        # Show DI raw output for inspection
        st.divider()
        st.markdown("### DI Raw Output Inspector")
        inspect_file = st.selectbox(
            "Inspect file",
            [""] + [f["name"] for f in llm_files],
            key="llm_inspect"
        )
        if inspect_file:
            fi = next((f for f in llm_files if f["name"] == inspect_file), None)
            if fi:
                if st.button(f"🔍 Run DI Preview — {inspect_file}"):
                    with st.spinner("Running DI..."):
                        try:
                            di_out = run_azure_di(fi["bytes"])
                            st.session_state[f"di_raw_{inspect_file}"] = di_out
                        except Exception as e:
                            st.error(str(e))

                raw_key = f"di_raw_{inspect_file}"
                if raw_key in st.session_state:
                    di_out = st.session_state[raw_key]
                    st.markdown("#### Header Fields")
                    hf = [
                        {"Label": k, "Value": v["value"], "Confidence": f"{v['confidence']*100:.0f}%"}
                        for k, v in di_out["header_fields"].items()
                    ]
                    st.dataframe(pd.DataFrame(hf), use_container_width=True)
                    for t_idx, t in enumerate(di_out.get("tables", [])):
                        st.markdown(f"#### Table {t_idx + 1}")
                        st.dataframe(pd.DataFrame(t["rows"]), use_container_width=True)

# ════════════════════════════════════════════════════════
# TAB 4 — Results & QC
# ════════════════════════════════════════════════════════
with tab4:
    st.subheader("Results & QC")

    rows = st.session_state.all_rows
    if not rows:
        st.info("Process invoices in Tab 2 or Tab 3 first")
    else:
        df = pd.DataFrame(rows)

        # ── QC Summary ─────────────────────────────────
        st.markdown("### QC Summary")
        for fname, qc in st.session_state.qc_results.items():
            mode = next(
                (r.get("extraction_mode","") for r in rows if r["file_name"] == fname), "—"
            )
            c1, c2, c3, c4 = st.columns([3, 1, 2, 4])
            c1.markdown(f"**{fname}**")
            c2.caption(mode)
            if qc.get("total_issue"):
                c3.error("❌ Mismatch")
                c4.warning(qc["total_issue"])
            else:
                c3.success("✅ OK")
                c4.caption(f"Sum of amounts: {qc.get('line_sum', 0):.2f}")

            if qc.get("row_issues"):
                with st.expander(f"⚠️ {len(qc['row_issues'])} row-level QC issues"):
                    for ri, msg in qc["row_issues"].items():
                        st.warning(f"Row {ri}: {msg}")

        st.divider()

        # ── Build display table ────────────────────────
        st.markdown("### Invoice Data")

        # Collect QC issue row indices
        all_issue_idx = set()
        g_idx = 0
        for fname, qc in st.session_state.qc_results.items():
            file_rows = [r for r in rows if r["file_name"] == fname]
            for local_idx in qc.get("row_issues", {}):
                all_issue_idx.add(g_idx + local_idx)
            g_idx += len(file_rows)

        # Order columns: fixed first, then extra
        fixed = [c for c in HEADER_COLS + LINE_COLS if c in df.columns]
        extra = [c for c in df.columns if c not in fixed]
        df    = df[[c for c in fixed + extra]]

        # QC flag column
        df.insert(0, "⚠️", ["⚠️" if i in all_issue_idx else "" for i in range(len(df))])

        # ── Filters ───────────────────────────────────
        fc1, fc2, fc3, fc4 = st.columns(4)
        f_file = fc1.multiselect("File",      df["file_name"].unique().tolist())
        f_mode = fc2.multiselect("Mode",      df["extraction_mode"].unique().tolist() if "extraction_mode" in df.columns else [])
        f_type = fc3.multiselect("Row Type",  df["row_type"].unique().tolist()        if "row_type"         in df.columns else [])
        f_qc   = fc4.checkbox("QC issues only")

        dv = df.copy()
        if f_file: dv = dv[dv["file_name"].isin(f_file)]
        if f_mode: dv = dv[dv["extraction_mode"].isin(f_mode)]
        if f_type: dv = dv[dv["row_type"].isin(f_type)]
        if f_qc:   dv = dv[dv["⚠️"] == "⚠️"]

        st.caption(f"Showing {len(dv)} of {len(df)} rows")

        def highlight(row):
            if row.get("⚠️") == "⚠️":
                return ["background-color:#fff3cd"] * len(row)
            rt = str(row.get("row_type",""))
            if rt.startswith("charge"):
                return ["background-color:#dbeafe"] * len(row)
            if rt in ("subtotal","total"):
                return ["background-color:#dcfce7;font-weight:bold"] * len(row)
            return [""] * len(row)

        st.dataframe(
            dv.style.apply(highlight, axis=1),
            use_container_width=True,
            height=520
        )
        st.caption(
            "🟡 Yellow = QC issue (qty×rate≠amount)  |  "
            "🔵 Blue = charge row  |  "
            "🟢 Green = subtotal/total row"
        )

        # ── Downloads ──────────────────────────────────
        st.divider()
        st.markdown("### Download")
        d1, d2 = st.columns(2)

        csv_full = df.drop(columns=["⚠️"], errors="ignore").to_csv(
            index=False
        ).encode("utf-8-sig")
        d1.download_button(
            "⬇️ Download Full CSV",
            data=csv_full,
            file_name=f"invoices_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv",
            mime="text/csv",
            use_container_width=True
        )

        csv_filt = dv.drop(columns=["⚠️"], errors="ignore").to_csv(
            index=False
        ).encode("utf-8-sig")
        d2.download_button(
            "⬇️ Download Filtered CSV",
            data=csv_filt,
            file_name=f"invoices_filtered_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv",
            mime="text/csv",
            use_container_width=True
        )

        # Per-file JSON
        st.markdown("### Raw JSON per File")
        for fname, extracted in st.session_state.all_extracted.items():
            with st.expander(f"📄 {fname}"):
                st.json(extracted)
                st.download_button(
                    f"⬇️ JSON — {fname}",
                    data=json.dumps(extracted, indent=2),
                    file_name=f"{fname}_extracted.json",
                    mime="application/json",
                    key=f"jdl_{fname}"
                )
