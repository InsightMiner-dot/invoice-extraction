                        with st.spinner(f"🔍 Azure DI: {fi['name']}"):
                            di_out = run_azure_di(fi["bytes"])

                        with st.spinner(f"🤖 LLM: {fi['name']}"):
                            extracted = extract_with_llm(di_out, charge_keywords)

                        rows = build_tabular_rows(fi["name"], extracted, "DI + LLM")
                        qc   = run_qc(rows, extracted)

                        st.session_state.all_extracted[fi["name"]] = extracted
                        st.session_state.all_rows.extend(rows)
