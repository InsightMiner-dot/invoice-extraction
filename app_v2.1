# ── Tabs ──────────────────────────────────────────────────────────────────────
tab1, tab2, tab3, tab4 = st.tabs([
    "1️⃣ Upload & Assign",
    "2️⃣ DI Only",
    "3️⃣ DI + LLM",
    "4️⃣ Results & QC"
])

# ════════════════════════════════════════════════════════
# TAB 1 — Upload & assign mode per file
# ════════════════════════════════════════════════════════
with tab1:
    st.subheader("Upload Invoices & Choose Mode")

    st.markdown("""
| Mode | How it works | Best for |
|---|---|---|
| **DI Only** | Azure DI extracts everything using keyword/hint matching. No LLM. | Clean digital PDFs, fast processing, zero LLM cost |
| **DI + LLM** | Azure DI extracts raw, then GPT-4o mini normalises and maps all fields | Scanned PDFs, complex layouts, mixed vendor formats |
""")

    uploaded = st.file_uploader(
        "Upload PDF or image invoices",
        type=["pdf", "jpg", "jpeg", "png"],
        accept_multiple_files=True
    )

    if uploaded:
        st.markdown("### Assign Mode Per File")

        # Bulk assign buttons
        b1, b2, b3 = st.columns(3)
        if b1.button("Set All → DI Only",  use_container_width=True):
            for f in uploaded:
                st.session_state[f"mode_{f.name}"] = "DI Only"
            st.rerun()
        if b2.button("Set All → DI + LLM", use_container_width=True):
            for f in uploaded:
                st.session_state[f"mode_{f.name}"] = "DI + LLM"
            st.rerun()

        st.divider()

        file_modes = {}
        for f in uploaded:
            c1, c2, c3 = st.columns([4, 3, 2])
            c1.markdown(f"📄 **{f.name}**")
            mode = c2.radio(
                "",
                ["DI Only", "DI + LLM"],
                horizontal=True,
                key=f"mode_{f.name}"
            )
            file_modes[f.name] = mode
            if f.name in st.session_state.processed:
                c3.success("✅ Done")
            else:
                c3.caption("⏳ Pending")

        st.divider()
        m1, m2, m3 = st.columns(3)
        m1.metric("Total",    len(uploaded))
        m2.metric("DI Only",  sum(1 for m in file_modes.values() if m == "DI Only"))
        m3.metric("DI + LLM", sum(1 for m in file_modes.values() if m == "DI + LLM"))

        # Store file bytes + mode
        files_info = []
        for f in uploaded:
            f.seek(0)
            files_info.append({
                "name":  f.name,
                "bytes": f.read(),
                "mode":  file_modes.get(f.name, "DI + LLM")
            })
        st.session_state.files_info = files_info

        st.info("→ Go to Tab 2 for DI Only files or Tab 3 for DI + LLM files")

# ════════════════════════════════════════════════════════
# TAB 2 — DI Only
# ════════════════════════════════════════════════════════
with tab2:
    st.subheader("DI Only Extraction")
    st.caption(
        "Azure DI extracts all key-value pairs and tables. "
        "Fields are matched to standard columns using keyword hints — same output format as DI+LLM."
    )

    di_files = [f for f in st.session_state.files_info if f["mode"] == "DI Only"]

    if not di_files:
        st.info("No files assigned to DI Only. Go to Tab 1 to upload and assign.")
    else:
        pending = [f for f in di_files if f["name"] not in st.session_state.processed]
        done    = [f for f in di_files if f["name"] in st.session_state.processed]

        m1, m2 = st.columns(2)
        m1.metric("Pending", len(pending))
        m2.metric("Done",    len(done))

        if done:
            st.success("Already processed: " + ", ".join(f["name"] for f in done))

        if pending:
            st.markdown("**Files to process:**")
            for f in pending:
                st.markdown(f"- 📄 {f['name']}")

            if st.button("⚡ Run DI Only — All Pending", type="primary", use_container_width=True):
                charge_keywords = st.session_state.charge_keywords
                progress = st.progress(0, text="Starting...")
                errors   = []

                for idx, fi in enumerate(pending):
                    progress.progress(idx / len(pending), text=f"Processing {fi['name']}...")
                    try:
                        with st.spinner(f"🔍 Azure DI: {fi['name']}"):
                            di_out = run_azure_di(fi["bytes"])

                        # Extract using same hint-based logic — no LLM
                        extracted = extract_di_only(di_out, charge_keywords)
                        rows      = build_tabular_rows_di_only(fi["name"], extracted, "DI Only")
                        qc        = run_qc(rows, extracted)

                        st.session_state.all_extracted[fi["name"]] = extracted
                        st.session_state.all_rows.extend(rows)
                        st.session_state.qc_results[fi["name"]]    = qc
                        st.session_state.processed.add(fi["name"])

                        n_items   = len(extracted.get("line_items") or [])
                        n_charges = len(extracted.get("charge_lines") or [])
                        st.success(
                            f"✅ {fi['name']} — "
                            f"{n_items} line items, {n_charges} charge rows, "
                            f"{len(rows)} total rows"
                        )

                    except Exception as e:
                        errors.append(f"{fi['name']}: {e}")
                        st.error(f"❌ {fi['name']}: {e}")

                progress.progress(1.0, text="Done!")
                if not errors:
                    st.success("All done → go to Tab 4 for results")

        # Show DI raw output for inspection
        st.divider()
        st.markdown("### DI Raw Output Inspector")
        inspect_file = st.selectbox(
            "Inspect file",
            [""] + [f["name"] for f in di_files],
            key="di_inspect"
        )
        if inspect_file:
            fi = next((f for f in di_files if f["name"] == inspect_file), None)
            if fi:
                if st.button(f"🔍 Run DI Preview — {inspect_file}"):
                    with st.spinner("Running DI..."):
                        try:
                            di_out = run_azure_di(fi["bytes"])
                            st.session_state[f"di_raw_{inspect_file}"] = di_out
                        except Exception as e:
                            st.error(str(e))

                raw_key = f"di_raw_{inspect_file}"
                if raw_key in st.session_state:
                    di_out = st.session_state[raw_key]

                    st.markdown("#### Header Fields (Key-Value Pairs)")
                    hf = [
                        {
                            "Label": k,
                            "Value": v["value"],
                            "Confidence": f"{v['confidence']*100:.0f}%"
                        }
                        for k, v in di_out["header_fields"].items()
                    ]
                    st.dataframe(pd.DataFrame(hf), use_container_width=True)

                    for t_idx, t in enumerate(di_out.get("tables", [])):
                        st.markdown(f"#### Table {t_idx + 1} — Page {t['page_number']}")
                        st.caption("Headers: " + " | ".join(t["headers"]))
                        st.dataframe(pd.DataFrame(t["rows"]), use_container_width=True)

                    with st.expander("Raw Text"):
                        st.text(di_out["raw_text"][:3000])

# ════════════════════════════════════════════════════════
# TAB 3 — DI + LLM
# ════════════════════════════════════════════════════════
with tab3:
    st.subheader("DI + LLM Extraction")
    st.caption(
        "Azure DI extracts raw structure → GPT-4o mini maps and normalises all fields. "
        "Handles any layout, any vendor, scanned PDFs."
