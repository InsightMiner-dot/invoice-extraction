# ── Helpers ───────────────────────────────────────────────────────────────────

def load_keywords():
    if os.path.exists(KEYWORDS_FILE):
        with open(KEYWORDS_FILE) as f:
            return json.load(f).get("keywords", list(DEFAULT_KEYWORDS))
    return list(DEFAULT_KEYWORDS)

def save_keywords(kws):
    with open(KEYWORDS_FILE, "w") as f:
        json.dump({"keywords": kws}, f, indent=2)

def get_llm_client():
    return AzureOpenAI(
        azure_endpoint=AZURE_OPENAI_ENDPOINT,
        api_key=AZURE_OPENAI_KEY,
        api_version=AZURE_OPENAI_API_VERSION,
    )

def to_float(v):
    if v is None:
        return None
    try:
        return float(re.sub(r"[^\d.\-]", "", str(v)))
    except Exception:
        return None

def is_charge(text: str, keywords: list) -> bool:
    t = str(text).lower()
    return any(kw.lower() in t for kw in keywords)

# ── Azure DI — same for both modes ───────────────────────────────────────────

def run_azure_di(file_bytes: bytes) -> dict:
    client = DocumentIntelligenceClient(DI_ENDPOINT, AzureKeyCredential(DI_KEY))
    poller = client.begin_analyze_document(
        "prebuilt-layout",
        body=file_bytes,
        content_type="application/octet-stream"
    )
    result = poller.result()

    output = {
        "raw_text":      result.content or "",
        "header_fields": {},
        "tables":        []
    }

    if result.key_value_pairs:
        for kv in result.key_value_pairs:
            if kv.key and kv.value:
                output["header_fields"][kv.key.content.strip()] = {
                    "value":      kv.value.content.strip(),
                    "confidence": round(kv.confidence or 0, 3)
                }

    if result.tables:
        for t_idx, table in enumerate(result.tables):
            headers, row_map = {}, {}
            page_num = 1
            for cell in table.cells:
                if cell.bounding_regions:
                    page_num = cell.bounding_regions[0].page_number
                if cell.row_index == 0:
                    headers[cell.column_index] = cell.content.strip()
                else:
                    r = cell.row_index
                    if r not in row_map:
                        row_map[r] = {}
                    col = headers.get(cell.column_index, f"col_{cell.column_index}")
                    row_map[r][col] = cell.content.strip()

            output["tables"].append({
                "table_index": t_idx,
                "headers":     list(headers.values()),
                "rows":        [row_map[k] for k in sorted(row_map.keys())],
                "page_number": page_num
            })

    return output

# ── DI-only extraction — same structure as LLM output ────────────────────────

def extract_di_only(di_output: dict, charge_keywords: list) -> dict:
    """
    Extract from DI output using keyword/hint matching.
    Produces EXACTLY the same dict structure as extract_with_llm().
    No LLM call made.
    """

    # ── Find header field value by keyword hints ──
    def find_val(standard_field):
        hints = DI_HINTS.get(standard_field, [])
        for k, v in di_output["header_fields"].items():
            k_lower = k.lower()
            if any(h.lower() in k_lower for h in hints):
                return v["value"]
        return None

    # ── Find table column name by keyword hints ───
    def find_col(headers, standard_col):
        hints = COL_HINTS.get(standard_col, [])
        for h in headers:
            h_lower = h.lower()
            if any(hint.lower() in h_lower for hint in hints):
                return h
        return None

    extracted = {
        "supplier_name":    find_val("supplier_name"),
        "supplier_id":      find_val("supplier_id"),
        "supplier_address": find_val("supplier_address"),
        "invoice_number":   find_val("invoice_number"),
        "invoice_date":     find_val("invoice_date"),
        "customer_name":    find_val("customer_name"),
        "customer_address": find_val("customer_address"),
        "remit_to":         find_val("remit_to"),
        "shipper_address":  find_val("shipper_address"),
        "bill_to":          find_val("bill_to"),
        "origin":           find_val("origin"),
        "destination":      find_val("destination"),
        "subtotal":         find_val("subtotal"),
        "total_amount":     find_val("total_amount"),
        "line_items":       [],
        "charge_lines":     [],
        "unmapped_header_fields": {}
    }

    # Collect unmapped header fields
    matched_keys = set()
    for std, hints in DI_HINTS.items():
        for k in di_output["header_fields"]:
            if any(h.lower() in k.lower() for h in hints):
                matched_keys.add(k)
    for k, v in di_output["header_fields"].items():
        if k not in matched_keys:
            extracted["unmapped_header_fields"][k] = v["value"]

    # ── Process tables ────────────────────────────
    for table in di_output.get("tables", []):
        headers  = table.get("headers", [])
        page_num = table.get("page_number", 1)

        # Map standard columns
        col = {std: find_col(headers, std) for std in COL_HINTS}

        # All columns not mapped to a standard field = extra
        mapped_headers = set(v for v in col.values() if v)
        extra_headers  = [h for h in headers if h not in mapped_headers]

        for row in table.get("rows", []):
            # Check if this entire row is a charge row
            row_text = " ".join(str(v) for v in row.values())
            desc_val = row.get(col["description"]) if col["description"] else row_text[:80]

            if is_charge(row_text, charge_keywords):
                # Find amount — last numeric value in row
                amt_val = row.get(col["amount"]) if col["amount"] else None
                if not amt_val:
                    for v in reversed(list(row.values())):
                        if to_float(v) is not None:
                            amt_val = v
                            break
                extracted["charge_lines"].append({
                    "description": desc_val,
                    "charge_type": "charge",
                    "amount":      amt_val,
                    "page_number": page_num
                })
            else:
                item = {
                    "page_number":         page_num,
                    "item_number":         row.get(col["item_number"])         if col["item_number"]         else None,
                    "manifest":            row.get(col["manifest"])            if col["manifest"]            else None,
                    "description":         row.get(col["description"])         if col["description"]         else None,
                    "quantity":            row.get(col["quantity"])            if col["quantity"]            else None,
                    "unit_of_measurement": row.get(col["unit_of_measurement"]) if col["unit_of_measurement"] else None,
                    "rate":                row.get(col["rate"])                if col["rate"]                else None,
                    "amount":              row.get(col["amount"])              if col["amount"]              else None,
                    "extra_columns":       {h: row.get(h) for h in extra_headers if row.get(h)}
                }
                extracted["line_items"].append(item)

    return extracted

# ── LLM extraction — unchanged ────────────────────────────────────────────────

def extract_with_llm(di_output: dict, charge_keywords: list) -> dict:
    prompt = f"""
You are an invoice data extraction assistant.

=== NUMBER RULES (ABSOLUTE) ===
- Copy ALL numeric values EXACTLY as they appear — do NOT fix, round, or change any number
- Do NOT calculate any missing number — return null if missing

=== EXTRACTION RULES ===
- Map fields by meaning regardless of label name
- supplier = vendor / seller / from / shipper
- customer = bill to / sold to / buyer / client
- remit_to = remittance address / pay to
- shipper_address = ship from address
- bill_to = billing address
- charge_keywords: {charge_keywords}
- Rows matching charge_keywords → add to charge_lines array
- Include page_number per row (default 1)
- Extra table columns not in standard → extra_columns dict per row
- Return ONLY valid JSON, no explanation, no markdown

DI RAW OUTPUT:
{json.dumps(di_output, indent=2)}

Return EXACTLY this structure (null for missing):
{{
  "supplier_name": null, "supplier_id": null, "supplier_address": null,
  "invoice_number": null, "invoice_date": null,
  "customer_name": null, "customer_address": null,
  "remit_to": null, "shipper_address": null, "bill_to": null,
  "origin": null, "destination": null,
  "subtotal": null, "total_amount": null,
  "line_items": [{{
    "page_number": 1, "item_number": null, "manifest": null,
    "description": null, "quantity": null, "unit_of_measurement": null,
    "rate": null, "amount": null, "extra_columns": {{}}
  }}],
  "charge_lines": [{{
    "description": null, "charge_type": null, "amount": null, "page_number": null
  }}],
  "unmapped_header_fields": {{}}
}}
"""
    response = get_llm_client().chat.completions.create(
        model=AZURE_OPENAI_DEPLOYMENT,
        messages=[
            {"role": "system", "content": "Extract invoice data. Never modify numbers. Return only valid JSON."},
            {"role": "user",   "content": prompt}
        ],
        max_tokens=3000,
        temperature=0
    )
    raw = re.sub(r"```json|```", "", response.choices[0].message.content.strip()).strip()
    return json.loads(raw)

# ── Build flat rows — identical for both modes ────────────────────────────────

def build_tabular_rows(filename: str, extracted: dict, mode: str) -> list:
    """
    Same function used for both DI-only and DI+LLM.
    Header columns repeat on every row.
    Charge lines become rows in description column.
    Subtotal and Total become their own rows.
    """
    rows = []

    header = {
        "file_name":        filename,
        "extraction_mode":  mode,
        "supplier_name":    extracted.get("supplier_name"),
        "supplier_id":      extracted.get("supplier_id"),
        "supplier_address": extracted.get("supplier_address"),
        "invoice_number":   extracted.get("invoice_number"),
        "invoice_date":     extracted.get("invoice_date"),
        "customer_name":    extracted.get("customer_name"),
        "customer_address": extracted.get("customer_address"),
        "remit_to":         extracted.get("remit_to"),
        "shipper_address":  extracted.get("shipper_address"),
        "bill_to":          extracted.get("bill_to"),
        "origin":           extracted.get("origin"),
        "destination":      extracted.get("destination"),
    }

    # Line item rows
    for item in (extracted.get("line_items") or []):
        row = dict(header)
        row.update({
            "page_number":         item.get("page_number", 1),
            "item_number":         item.get("item_number"),
            "manifest":            item.get("manifest"),
            "description":         item.get("description"),
            "quantity":            item.get("quantity"),
            "unit_of_measurement": item.get("unit_of_measurement"),
            "rate":                item.get("rate"),
            "amount":              item.get("amount"),
            "subtotal":            None,
            "total":               None,
            "row_type":            "line_item"
        })
        for k, v in (item.get("extra_columns") or {}).items():
            row[k] = v
        rows.append(row)

    # Charge rows — appear as line items, description = charge name
    for charge in (extracted.get("charge_lines") or []):
        row = dict(header)
        row.update({
            "page_number":         charge.get("page_number", ""),
            "item_number":         None,
            "manifest":            None,
            "description":         charge.get("description"),
            "quantity":            None,
            "unit_of_measurement": None,
            "rate":                None,
            "amount":              charge.get("amount"),
            "subtotal":            None,
            "total":               None,
            "row_type":            f"charge:{charge.get('charge_type','other')}"
        })
        rows.append(row)

    # Subtotal row
    if extracted.get("subtotal"):
        row = dict(header)
        row.update({
            "page_number": "", "item_number": None, "manifest": None,
            "description": "SUBTOTAL", "quantity": None,
            "unit_of_measurement": None, "rate": None, "amount": None,
            "subtotal": extracted.get("subtotal"), "total": None,
            "row_type": "subtotal"
        })
        rows.append(row)

    # Total row
    if extracted.get("total_amount"):
        row = dict(header)
        row.update({
            "page_number": "", "item_number": None, "manifest": None,
            "description": "TOTAL", "quantity": None,
            "unit_of_measurement": None, "rate": None, "amount": None,
            "subtotal": None, "total": extracted.get("total_amount"),
            "row_type": "total"
        })
        rows.append(row)

    return rows

# ── QC ────────────────────────────────────────────────────────────────────────

def run_qc(rows: list, extracted: dict) -> dict:
    issues       = {}
    total_amount = to_float(extracted.get("total_amount"))
    line_sum     = 0.0

    for i, row in enumerate(rows):
        if row.get("row_type") in ("subtotal", "total"):
            continue
        amt = to_float(row.get("amount"))
        if amt is not None:
            line_sum += amt

        qty  = to_float(row.get("quantity"))
        rate = to_float(row.get("rate"))
        if qty is not None and rate is not None and amt is not None:
            expected = round(qty * rate, 2)
            if abs(expected - round(amt, 2)) > 0.02:
                issues[i] = f"Qty×Rate={qty}×{rate}={expected} ≠ amount={amt}"

    total_issue = None
    if total_amount and abs(line_sum - total_amount) > 0.5:
        total_issue = (
            f"Sum of amounts ({line_sum:.2f}) ≠ invoice total ({total_amount:.2f})"
        )

    return {"row_issues": issues, "total_issue": total_issue, "line_sum": line_sum}

