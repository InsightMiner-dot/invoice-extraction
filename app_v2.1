    llm_files = [f for f in st.session_state.files_info if f["mode"] == "DI + LLM"]

    if not llm_files:
        st.info("No files assigned to DI + LLM. Go to Tab 1 to upload and assign.")
    else:
        pending = [f for f in llm_files if f["name"] not in st.session_state.processed]
        done    = [f for f in llm_files if f["name"] in st.session_state.processed]

