# ── Persistence ───────────────────────────────────────────────────────────────
def load_registry():
    return json.load(open(REGISTRY_FILE)) if os.path.exists(REGISTRY_FILE) else {}

def save_registry(r):
    json.dump(r, open(REGISTRY_FILE,"w"), indent=2)

def load_keywords():
    return json.load(open(KEYWORDS_FILE)).get("keywords", DEFAULT_KEYWORDS) if os.path.exists(KEYWORDS_FILE) else list(DEFAULT_KEYWORDS)

def save_keywords(k):
    json.dump({"keywords": k}, open(KEYWORDS_FILE,"w"), indent=2)

# ── Utils ─────────────────────────────────────────────────────────────────────
def to_float(v):
    try:    return float(re.sub(r"[^\d.\-]","",str(v)))
    except: return None

def get_llm():
    return AzureOpenAI(azure_endpoint=AZURE_OPENAI_ENDPOINT, api_key=AZURE_OPENAI_KEY, api_version=AZURE_OPENAI_API_VERSION)

# ── Azure DI ──────────────────────────────────────────────────────────────────
def run_di(file_bytes):
    c = DocumentIntelligenceClient(DI_ENDPOINT, AzureKeyCredential(DI_KEY))
    r = c.begin_analyze_document("prebuilt-layout", body=file_bytes, content_type="application/octet-stream").result()
    out = {"raw_text": r.content or "", "header_fields": {}, "tables": []}
    if r.key_value_pairs:
        for kv in r.key_value_pairs:
            if kv.key and kv.value:
                out["header_fields"][kv.key.content.strip()] = {
                    "value": kv.value.content.strip(),
                    "confidence": round(kv.confidence or 0, 3)
                }
    if r.tables:
        for t in r.tables:
            headers, row_map, page_num = {}, {}, 1
            for cell in t.cells:
                if cell.bounding_regions: page_num = cell.bounding_regions[0].page_number
                if cell.row_index == 0:
                    headers[cell.column_index] = cell.content.strip()
                else:
                    row_map.setdefault(cell.row_index, {})[headers.get(cell.column_index, f"col_{cell.column_index}")] = cell.content.strip()
            out["tables"].append({
                "headers":     list(headers.values()),
                "rows":        [row_map[k] for k in sorted(row_map)],
                "page_number": page_num
            })
    return out

# ── DI-only extraction ────────────────────────────────────────────────────────
def extract_di_only(di_out, keywords, file_di_map):
    def find(std):
        custom = file_di_map.get(std)
        if custom:
            for k,v in di_out["header_fields"].items():
                if k.lower() == custom.lower(): return v["value"]
        for k,v in di_out["header_fields"].items():
            if any(h in k.lower() for h in DI_HINTS.get(std,[])):
                return v["value"]
        return None

    ext = {s: find(s) for s in STANDARD_HEADER}
    ext.update({"line_items":[], "charge_lines":[], "unmapped_header_fields":{}})

    col_map = file_di_map.get("_columns", {})

    def detect(hints):
        for h in di_out.get("tables",[{}])[0].get("headers",[]):
            if h in col_map and col_map[h] in hints: return h
            if any(x.lower() in h.lower() for x in hints): return h
        return None

    col_item   = detect(["item","item no","sr no","line"])
    col_mfst   = detect(["manifest","awb","bol","tracking"])
    col_desc   = detect(["description","particulars","product","goods","details","service"])
    col_qty    = detect(["qty","quantity","nos","units","pcs"])
    col_uom    = detect(["uom","unit","measure"])
    col_rate   = detect(["rate","unit price","unit cost","price"])
    col_amount = detect(["amount","total","line total","net amount","ext"])

    std_set = {col_item,col_mfst,col_desc,col_qty,col_uom,col_rate,col_amount}

    for table in di_out.get("tables",[]):
        pg = table.get("page_number",1)
        for row in table.get("rows",[]):
            row_text = " ".join(str(v) for v in row.values()).lower()
            if any(kw in row_text for kw in keywords):
                amt = row.get(col_amount) if col_amount else next((v for v in reversed(list(row.values())) if to_float(v) is not None), None)
                ext["charge_lines"].append({"description": row.get(col_desc,"") or row_text[:60], "charge_type":"charge", "amount": amt, "page_number": pg})
            else:
                extra = {h:v for h,v in row.items() if h not in std_set and h}
                ext["line_items"].append({
                    "page_number":         pg,
                    "item_number":         row.get(col_item)   if col_item   else None,
                    "manifest":            row.get(col_mfst)   if col_mfst   else None,
                    "description":         row.get(col_desc)   if col_desc   else None,
                    "quantity":            row.get(col_qty)    if col_qty    else None,
                    "unit_of_measurement": row.get(col_uom)    if col_uom    else None,
                    "rate":                row.get(col_rate)   if col_rate   else None,
                    "amount":              row.get(col_amount) if col_amount else None,
                    "extra_columns":       extra
                })

    mapped = set()
    for std in STANDARD_HEADER:
        hints = DI_HINTS.get(std,[])
        custom = file_di_map.get(std,"")
        for k in di_out["header_fields"]:
            if (custom and k.lower()==custom.lower()) or any(h in k.lower() for h in hints):
                mapped.add(k)
    for k,v in di_out["header_fields"].items():
        if k not in mapped:
            ext["unmapped_header_fields"][k] = v["value"]

    return ext

# ── LLM extraction ────────────────────────────────────────────────────────────
def extract_llm(di_out, keywords):
    prompt = f"""Extract invoice data from the Azure DI output below.

RULES:
- Copy ALL numbers EXACTLY as-is. Never fix or calculate any number.
- Map fields by meaning regardless of label name.
- Rows matching these keywords go into charge_lines: {keywords}
- Return ONLY valid JSON.

DI OUTPUT:
{json.dumps(di_out, indent=2)}

JSON structure:
{{
  "supplier_name":null,"supplier_id":null,"supplier_address":null,
  "invoice_number":null,"invoice_date":null,
  "customer_name":null,"customer_address":null,
  "remit_to":null,"shipper_address":null,"bill_to":null,
  "origin":null,"destination":null,
  "subtotal":null,"total_amount":null,
  "line_items":[{{"page_number":1,"item_number":null,"manifest":null,
    "description":null,"quantity":null,"unit_of_measurement":null,
    "rate":null,"amount":null,"extra_columns":{{}}}}],
  "charge_lines":[{{"description":null,"charge_type":null,"amount":null,"page_number":null}}],
  "unmapped_header_fields":{{}}
}}"""

    r = get_llm().chat.completions.create(
        model=AZURE_OPENAI_DEPLOYMENT,
        messages=[
            {"role":"system","content":"Extract invoice data. Never modify numbers. Return only valid JSON."},
            {"role":"user","content":prompt}
        ],
        max_tokens=3000, temperature=0
    )
    raw = re.sub(r"```json|```","",r.choices[0].message.content.strip()).strip()
    return json.loads(raw)

# ── Build rows ────────────────────────────────────────────────────────────────
def build_rows(filename, ext, mode):
    header = {
        "file_name":filename,"extraction_mode":mode,
        "supplier_name":ext.get("supplier_name"),"supplier_id":ext.get("supplier_id"),
        "supplier_address":ext.get("supplier_address"),"invoice_number":ext.get("invoice_number"),
        "invoice_date":ext.get("invoice_date"),"customer_name":ext.get("customer_name"),
        "customer_address":ext.get("customer_address"),"remit_to":ext.get("remit_to"),
        "shipper_address":ext.get("shipper_address"),"bill_to":ext.get("bill_to"),
        "origin":ext.get("origin"),"destination":ext.get("destination"),
    }
    rows = []
    for item in (ext.get("line_items") or []):
        row = dict(header)
        row.update({"page_number":item.get("page_number",1),"item_number":item.get("item_number"),
            "manifest":item.get("manifest"),"description":item.get("description"),
            "quantity":item.get("quantity"),"unit_of_measurement":item.get("unit_of_measurement"),
            "rate":item.get("rate"),"amount":item.get("amount"),
            "subtotal":None,"total":None,"row_type":"line_item"})
        for k,v in (item.get("extra_columns") or {}).items(): row[k]=v
        rows.append(row)
    for ch in (ext.get("charge_lines") or []):
        row = dict(header)
        row.update({"page_number":ch.get("page_number",""),"item_number":None,"manifest":None,
            "description":ch.get("description"),"quantity":None,"unit_of_measurement":None,
            "rate":None,"amount":ch.get("amount"),"subtotal":None,"total":None,
            "row_type":f"charge:{ch.get('charge_type','other')}"})
        rows.append(row)
    if ext.get("subtotal"):
        row = dict(header); row.update({"page_number":"","item_number":None,"manifest":None,
            "description":"SUBTOTAL","quantity":None,"unit_of_measurement":None,"rate":None,
            "amount":None,"subtotal":ext.get("subtotal"),"total":None,"row_type":"subtotal"})
        rows.append(row)
    if ext.get("total_amount"):
        row = dict(header); row.update({"page_number":"","item_number":None,"manifest":None,
            "description":"TOTAL","quantity":None,"unit_of_measurement":None,"rate":None,
            "amount":None,"subtotal":None,"total":ext.get("total_amount"),"row_type":"total"})
        rows.append(row)
    return rows

# ── QC ────────────────────────────────────────────────────────────────────────
def run_qc(rows, ext):
    issues, line_sum = {}, 0.0
    total = to_float(ext.get("total_amount"))
    for i, row in enumerate(rows):
        if row.get("row_type") in ("subtotal","total"): continue
        amt = to_float(row.get("amount"))
        if amt: line_sum += amt
        qty, rate = to_float(row.get("quantity")), to_float(row.get("rate"))
        if qty and rate and amt:
            exp = round(qty*rate,2)
            if abs(exp - round(amt,2)) > 0.02:
                issues[i] = f"{qty}×{rate}={exp} ≠ {amt}"
    total_issue = f"Sum {line_sum:.2f} ≠ total {total:.2f}" if total and abs(line_sum-total)>0.5 else None
    return {"row_issues":issues,"total_issue":total_issue,"line_sum":line_sum}

