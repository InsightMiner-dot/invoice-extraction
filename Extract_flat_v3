import os
import pandas as pd
from openpyxl import Workbook
from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
from openpyxl.utils import get_column_letter
from azure.ai.documentintelligence import DocumentIntelligenceClient
from azure.ai.documentintelligence.models import AnalyzeResult
from azure.ai.documentintelligence.models import AnalyzeDocumentRequest
from azure.core.credentials import AzureKeyCredential


# ── Config ─────────────────────────────────────────────────────────────────────
ENDPOINT  = "<your-endpoint>"
KEY       = "<your-key>"
MODEL_ID  = "prebuilt-invoice"
OUTPUT_XL = "invoices_flat.xlsx"

PDF_FILES = [
    "invoice1.pdf",
    "invoice2.pdf",
]

# ── Field classification helpers ───────────────────────────────────────────────
# SubTotal / Total are columns on the LAST item row — not separate rows
SUBTOTAL_NAMES = {"subtotal", "sub-total", "subtotalamount"}
TOTAL_NAMES    = {"invoicetotal", "amountdue", "totalamount", "total", "grandtotal", "balance"}

# Charge fields → dynamic CHARGE rows appended after item rows
# Only what Azure actually returns will be inserted — nothing assumed/hardcoded
CHARGE_KEYWORDS = [
    "tax", "hst", "gst", "pst", "vat", "salestax",
    "freight", "frt", "handling", "shipping", "delivery",
    "surcharge", "fuelsurcharge", "discount", "adjustment",
    "fee", "servicecharge", "insurance", "misc",
    "environmentalfee", "recyclingfee", "duty",
]

def _norm(name: str) -> str:
    return name.lower().replace(" ", "").replace("/", "").replace("_", "").replace("-", "")

def is_subtotal(name: str) -> bool:
    return _norm(name) in SUBTOTAL_NAMES

def is_total(name: str) -> bool:
    return _norm(name) in TOTAL_NAMES

def is_charge(name: str) -> bool:
    n = _norm(name)
    return any(kw in n for kw in CHARGE_KEYWORDS)


# ── Azure ──────────────────────────────────────────────────────────────────────

def run_analysis(pdf_path: str) -> AnalyzeResult:
    with open(pdf_path, "rb") as f:
        pdf_bytes = f.read()
    client = DocumentIntelligenceClient(endpoint=ENDPOINT, credential=AzureKeyCredential(KEY))
    poller = client.begin_analyze_document(
        MODEL_ID,
        AnalyzeDocumentRequest(bytes_source=pdf_bytes),
        content_type="application/json",
    )
    return poller.result()


# ── Helpers ────────────────────────────────────────────────────────────────────

def get_content_conf(field) -> tuple[str, str]:
    if not field:
        return "", ""
    content = field.get("content") or ""
    conf    = field.get("confidence")
    return content, (f"{round(conf * 100, 1)}" if conf else "")


def get_page(field) -> str:
    br = field.get("boundingRegions") or []
    return str(br[0].get("pageNumber", "")) if br else ""


def get_currency(field) -> str:
    """Extract currency code from valueCurrency dict or any string value."""
    if not field:
        return ""
    vc = field.get("valueCurrency")
    if vc and isinstance(vc, dict):
        return vc.get("currencyCode") or ""
    return ""


def discover_item_cols(items_array: list) -> list[str]:
    """Dynamically discover all valueObject keys across every item."""
    seen, order = set(), []
    for item in items_array:
        for k in (item.get("valueObject") or {}).keys():
            if k not in seen:
                seen.add(k)
                order.append(k)
    return order


# ── Row Extractor ──────────────────────────────────────────────────────────────

def extract_rows(filename: str, result: AnalyzeResult) -> tuple[list[dict], list[str]]:
    """
    Row layout per invoice:

      [ITEM rows]   — one per line item; invoice header fields repeat on every row;
                      SubTotal and InvoiceTotal values sit as columns on the LAST item row only.

      [CHARGE rows] — one per charge field actually found in this invoice
                      (Tax, HST, TotalTax, Freight, etc. — only what Azure detected).
                      Uses Description + Amount columns to stay aligned with item rows.
                      Nothing inserted if no charges found.

    Currency is a column that repeats on every row.
    """
    rows          = []
    all_item_keys = []
    seen_item     = set()

    if not result.documents:
        return rows, all_item_keys

    for doc in result.documents:
        if not doc.fields:
            continue

        overall_conf = f"{round(doc.confidence * 100, 1)}" if doc.confidence else ""

        # ── Bucket every invoice-level field ──────────────────────────────────
        invoice_cols  = {}   # repeat on every row
        charge_fields = {}   # → dynamic CHARGE rows (only what exists)
        subtotal_fld  = None
        total_fld     = None
        currency_code = ""

        for fname, fval in doc.fields.items():
            if fname == "Items":
                continue

            content, conf = get_content_conf(fval)

            # Try currency from this field
            if not currency_code:
                currency_code = get_currency(fval)

            if is_subtotal(fname):
                subtotal_fld = (fname, fval)

            elif is_total(fname):
                # prefer InvoiceTotal if multiple total-like fields exist
                if total_fld is None or _norm(fname) == "invoicetotal":
                    total_fld = (fname, fval)

            elif is_charge(fname):
                # Only add if it has an actual value — no empty charge rows
                if content:
                    charge_fields[fname] = fval

            else:
                invoice_cols[fname]            = content
                invoice_cols[f"{fname} Conf%"] = conf

        # ── Items array ────────────────────────────────────────────────────────
        items_field = doc.fields.get("Items")
        items_array = (items_field.get("valueArray") or []) if items_field else []
        item_keys   = discover_item_cols(items_array)

        for k in item_keys:
            if k not in seen_item:
                seen_item.add(k)
                all_item_keys.append(k)

        # Try currency from item fields if still empty
        if not currency_code:
            for item in items_array:
                obj = item.get("valueObject") or {}
                for col in ("UnitPrice", "Amount", "Total", "Rate"):
                    cc = get_currency(obj.get(col) or {})
                    if cc:
                        currency_code = cc
                        break
                if currency_code:
                    break

        # ── Base that repeats on every row ─────────────────────────────────────
        base = {
            "File Name":    filename,
            "Page":         "",
            "Row Type":     "ITEM",
            "Currency":     currency_code,
            "Overall Conf": overall_conf,
        }
        base.update(invoice_cols)

        # SubTotal and Total as columns (go on last item row only)
        subtotal_val  = get_content_conf(subtotal_fld[1])[0] if subtotal_fld else ""
        subtotal_conf = get_content_conf(subtotal_fld[1])[1] if subtotal_fld else ""
        total_val     = get_content_conf(total_fld[1])[0]    if total_fld    else ""
        total_conf    = get_content_conf(total_fld[1])[1]    if total_fld    else ""

        # ── ITEM rows ──────────────────────────────────────────────────────────
        item_rows = []
        if items_array:
            for item in items_array:
                obj = item.get("valueObject") or {}

                item_page = ""
                for col in item_keys:
                    f = obj.get(col)
                    if f:
                        pg = get_page(f)
                        if pg:
                            item_page = pg
                            break

                row           = dict(base)
                row["Page"]   = item_page

                for col in item_keys:
                    f                   = obj.get(col)
                    content, conf       = get_content_conf(f) if f else ("", "")
                    row[col]            = content
                    row[f"{col} Conf%"] = conf

                item_rows.append(row)
        else:
            # No items — still one row so invoice header is captured
            item_rows.append(dict(base))

        # Put SubTotal and Total values on the LAST item row as columns
        if item_rows:
            last = item_rows[-1]
            if subtotal_val:
                last["SubTotal"]        = subtotal_val
                last["SubTotal Conf%"]  = subtotal_conf
            if total_val:
                last["InvoiceTotal"]       = total_val
                last["InvoiceTotal Conf%"] = total_conf

        rows.extend(item_rows)

        # ── CHARGE rows — only what was actually found ─────────────────────────
        # Each charge field that Azure detected becomes one row.
        # Description col = charge name, Amount col = charge value.
        for fname, fval in charge_fields.items():
            content, conf = get_content_conf(fval)
            row                      = dict(base)
            row["Row Type"]          = "CHARGE"
            row["Page"]              = get_page(fval)
            row["Description"]       = fname        # charge label
            row["Description Conf%"] = ""
            row["Amount"]            = content      # charge value
            row["Amount Conf%"]      = conf
            # Clear all other item cols so they don't carry over
            for col in item_keys:
                if col not in ("Description", "Amount"):
                    row[col]            = ""
                    row[f"{col} Conf%"] = ""
            rows.append(row)

    return rows, all_item_keys


# ── Collect across all PDFs ────────────────────────────────────────────────────

def collect_all(pdf_files: list[str]) -> tuple[pd.DataFrame, set[str]]:
    all_rows      = []
    all_item_keys = []
    seen_item     = set()

    for pdf_path in pdf_files:
        print(f"  Analyzing: {pdf_path} ...")
        try:
            result          = run_analysis(pdf_path)
            rows, item_keys = extract_rows(os.path.basename(pdf_path), result)
            all_rows.extend(rows)
            for k in item_keys:
                if k not in seen_item:
                    seen_item.add(k)
                    all_item_keys.append(k)
            print(f"    → {len(rows)} row(s) | item cols: {item_keys}")
        except Exception as e:
            print(f"    ✗ Error: {e}")
            all_rows.append({"File Name": os.path.basename(pdf_path), "Error": str(e)})

    if not all_rows:
        return pd.DataFrame(), set()

    # ── Column order ───────────────────────────────────────────────────────────
    all_keys = []
    seen_all = set()
    for row in all_rows:
        for k in row.keys():
            if k not in seen_all:
                all_keys.append(k)
                seen_all.add(k)

    META = ["File Name", "Page", "Row Type", "Currency", "Overall Conf"]

    # SubTotal and InvoiceTotal pinned just before item cols
    SUMMARY_COLS = []
    for sc in ["SubTotal", "SubTotal Conf%", "InvoiceTotal", "InvoiceTotal Conf%"]:
        if sc in seen_all:
            SUMMARY_COLS.append(sc)

    item_and_conf = []
    for k in all_item_keys:
        item_and_conf += [k, f"{k} Conf%"]

    end_set  = set(item_and_conf) | set(SUMMARY_COLS) | {"Error"}
    meta_set = set(META)
    inv_cols = [k for k in all_keys if k not in meta_set and k not in end_set]

    final_cols = META + inv_cols + SUMMARY_COLS + item_and_conf
    if "Error" in seen_all:
        final_cols.append("Error")

    df = pd.DataFrame(all_rows, columns=final_cols)
    df = df.fillna("")
    return df, set(all_item_keys)


# ── Excel Writer ───────────────────────────────────────────────────────────────

THIN   = Side(style="thin", color="CCCCCC")
BORDER = Border(left=THIN, right=THIN, top=THIN, bottom=THIN)
ALT    = PatternFill("solid", start_color="EBF5FB")

CHARGE_FILL   = PatternFill("solid", start_color="FEF9E7")   # yellow  — charge rows
CHARGE_FONT   = Font(name="Arial", size=10, italic=True)


def col_color(col_name: str, item_cols: set) -> str:
    if col_name in ("File Name", "Page", "Row Type", "Currency", "Overall Conf"):
        return "1C2833"
    if col_name in ("SubTotal", "InvoiceTotal"):
        return "1A5276"
    if col_name.endswith("Conf%"):
        return "1E8449"
    if col_name in item_cols:
        return "154360"
    return "1A5276"


def write_excel(df: pd.DataFrame, item_cols: set, output_path: str):
    wb = Workbook()
    ws = wb.active
    ws.title = "Invoices"

    # Headers
    for col_idx, col_name in enumerate(df.columns, start=1):
        cell           = ws.cell(row=1, column=col_idx, value=col_name)
        cell.font      = Font(bold=True, color="FFFFFF", name="Arial", size=10)
        cell.fill      = PatternFill("solid", start_color=col_color(col_name, item_cols))
        cell.alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)
        cell.border    = BORDER
    ws.row_dimensions[1].height = 35

    row_type_idx = list(df.columns).index("Row Type") if "Row Type" in df.columns else None

    # Data rows
    for row_idx, row in enumerate(df.itertuples(index=False), start=2):
        row_type = str(row[row_type_idx]) if row_type_idx is not None else ""
        is_charge_row = row_type == "CHARGE"

        for col_idx, value in enumerate(row, start=1):
            cell      = ws.cell(row=row_idx, column=col_idx, value=value if value != "" else "")
            cell.font = CHARGE_FONT if is_charge_row else Font(name="Arial", size=10)
            cell.alignment = Alignment(vertical="center")
            cell.border    = BORDER
            if is_charge_row:
                cell.fill = CHARGE_FILL
            elif row_idx % 2 == 0:
                cell.fill = ALT

    # Column widths
    for col_idx, col_name in enumerate(df.columns, start=1):
        if col_name.endswith("Conf%"):
            width = 10
        elif col_name == "File Name":
            width = 25
        elif col_name in ("Page", "Row Type", "Currency", "Overall Conf"):
            width = 13
        else:
            vals  = [str(col_name)] + [str(v) for v in df.iloc[:, col_idx - 1] if v != ""]
            width = min(max((len(v) for v in vals), default=10), 45) + 3
        ws.column_dimensions[get_column_letter(col_idx)].width = width

    ws.freeze_panes    = "E2"
    ws.auto_filter.ref = ws.dimensions

    wb.save(output_path)
    print(f"\n✅ Saved → {output_path}")
    print(f"   Rows           : {len(df)}")
    print(f"   Total columns  : {len(df.columns)}")
    print(f"   Item cols found: {sorted(item_cols)}")


# ── Main ───────────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    print("Starting extraction...\n")
    df, item_cols = collect_all(PDF_FILES)
    if df.empty:
        print("No data extracted.")
    else:
        print(f"\nBuilding Excel...")
        write_excel(df, item_cols, OUTPUT_XL)
