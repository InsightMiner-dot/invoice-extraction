{
  "_comment": "FIELD CONFIGURATION — single source of truth. Edit this file to add/remove/alias fields. No code changes needed.",
  "_instructions": [
    "aliases: all label variations LLM should look for on the document (case-insensitive)",
    "required: if true, missing value is flagged in validation",
    "csv_column: exact column header written to output CSV",
    "is_line_item: true = appears per row in line_items, false = appears once in header",
    "To ADD a new field: add a new key block with aliases and csv_column. Pipeline picks it up automatically.",
    "STRICT MODE: LLM will ONLY extract text present on document. It will NEVER infer, calculate, or assume values."
  ],

  "header_fields": {

    "file_name": {
      "csv_column": "File Name",
      "aliases": [],
      "required": true,
      "source": "system",
      "_note": "Auto-populated from file path. Not extracted from document."
    },

    "supplier_name": {
      "csv_column": "Supplier Name",
      "aliases": [
        "vendor name", "vendor", "supplier", "billed by", "from",
