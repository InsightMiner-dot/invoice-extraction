  "tax_line_items": {
    "_note": "Tax charges are extracted as separate line items with description = tax type found on document.",
    "known_tax_labels": [
      "tax", "gst", "cgst", "sgst", "igst", "vat", "hst", "pst", "qst",
      "service tax", "sales tax", "excise duty", "cess", "surcharge",
      "tds", "withholding tax", "freight tax", "fuel surcharge tax",
      "state tax", "federal tax", "county tax", "import duty"
    ],
    "_instruction": "Any line matching a known_tax_label (or any label containing 'tax', 'duty', 'surcharge', 'cess') should be extracted as a separate line item row, not merged into other lines."
  }
