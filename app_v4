def run_analysis(endpoint: str, key: str, pdf_bytes: bytes, model_id: str = "prebuilt-invoice"):
    client = DocumentIntelligenceClient(endpoint=endpoint, credential=AzureKeyCredential(key))
    poller = client.begin_analyze_document(
        model_id,
        AnalyzeDocumentRequest(bytes_source=pdf_bytes),
        content_type="application/json",
    )
    return poller.result()


def extract_fields(result: AnalyzeResult) -> dict:
    """Extract all fields — uses .get() pattern matching official Azure SDK sample."""
    fields = {}
    if result.documents:
        for doc in result.documents:
            if doc.fields:
                for name, field in doc.fields.items():
                    content    = field.get("content")
                    confidence = field.get("confidence")
                    br         = field.get("boundingRegions") or []
                    polygon    = br[0].get("polygon", []) if br else []
                    page       = br[0].get("pageNumber", 1) if br else 1
                    # polygon may be [{x,y},...] -> flatten to [x1,y1,x2,y2,...]
                    if polygon and isinstance(polygon[0], dict):
                        polygon = [c for pt in polygon for c in (pt["x"], pt["y"])]
                    fields[name] = {
                        "value":      content,
                        "confidence": round(confidence * 100, 1) if confidence else None,
                        "polygon":    polygon,
                        "page":       page,
                    }
    return fields


def extract_kv_pairs(result) -> list:
    """Extract key-value pairs."""
    pairs = []
    if hasattr(result, "key_value_pairs") and result.key_value_pairs:
        for kv in result.key_value_pairs:
            key_text = kv.key.content if kv.key else ""
            val_text = kv.value.content if kv.value else ""
            conf = round(kv.confidence * 100, 1) if kv.confidence else None
            key_poly = get_polygon(kv.key.bounding_regions[0]) if kv.key and kv.key.bounding_regions else []
            val_poly = get_polygon(kv.value.bounding_regions[0]) if kv.value and kv.value.bounding_regions else []
            page = kv.key.bounding_regions[0].page_number if kv.key and kv.key.bounding_regions else 1
            pairs.append({
                "key": key_text, "value": val_text,
                "confidence": conf,
                "key_polygon": key_poly, "val_polygon": val_poly,
                "page": page,
            })
    return pairs


def extract_tables(result) -> list:
    """Extract tables."""
    tables = []
    if hasattr(result, "tables") and result.tables:
        for t in result.tables:
            cells = {}
            for cell in t.cells:
                cells[(cell.row_index, cell.column_index)] = cell.content
            tables.append({
                "rows": t.row_count,
                "cols": t.column_count,
                "cells": cells,
                "page": t.bounding_regions[0].page_number if t.bounding_regions else 1,
            })
    return tables


