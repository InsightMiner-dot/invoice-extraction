# ── Helpers ────────────────────────────────────────────────────────────────────

def flatten_polygon(raw_poly: list) -> list:
    """Safely flatten polygon points to [x1,y1,x2,y2,...].
    Azure SDK returns polygon as list of objects with .x/.y attributes (inches).
    """
    result = []
    for pt in (raw_poly or []):
        if hasattr(pt, "x"):
            result += [pt.x, pt.y]        # SDK object (most common)
        elif isinstance(pt, dict):
            result += [pt["x"], pt["y"]]  # dict fallback
        elif isinstance(pt, (int, float)):
            result.append(pt)             # already flat
    return result


def pdf_page_to_pil(pdf_bytes: bytes, page_num: int = 0, dpi: int = 150) -> Image.Image:
    doc  = fitz.open(stream=pdf_bytes, filetype="pdf")
    page = doc[page_num]
    mat  = fitz.Matrix(dpi / 72, dpi / 72)
    pix  = page.get_pixmap(matrix=mat)
    img  = Image.frombytes("RGB", [pix.width, pix.height], pix.samples)
    doc.close()
    return img


def draw_bounding_boxes(img: Image.Image, polygons: list, labels: list,
                        page_w_in: float = 8.5, page_h_in: float = 11.0) -> Image.Image:
    """
    polygons: list of [x1,y1,x2,y2,...] in inches (as returned by Azure SDK)
    page_w_in / page_h_in: page dimensions in inches from result.pages
    Converts inch coords -> pixel coords using the rendered image size.
    """
    img  = img.copy()
    draw = ImageDraw.Draw(img, "RGBA")
    px_w, px_h = img.size
    scale_x = px_w / page_w_in
    scale_y = px_h / page_h_in
    for poly, label in zip(polygons, labels):
        if not poly or len(poly) < 4:
            continue
        points = [(poly[i] * scale_x, poly[i + 1] * scale_y) for i in range(0, len(poly), 2)]
        draw.polygon(points, fill=(59, 130, 246, 40), outline=(59, 130, 246, 200))
        if label:
            x0, y0 = points[0]
            draw.rectangle([x0, y0 - 14, x0 + len(label) * 6 + 4, y0], fill=(30, 64, 175, 200))
            draw.text((x0 + 2, y0 - 13), label[:25], fill="white")
    return img


def run_analysis(endpoint: str, key: str, pdf_bytes: bytes, model_id: str) -> AnalyzeResult:
    client = DocumentIntelligenceClient(endpoint=endpoint, credential=AzureKeyCredential(key))
    poller = client.begin_analyze_document(
        model_id,
        AnalyzeDocumentRequest(bytes_source=pdf_bytes),
        content_type="application/json",
    )
    return poller.result()


def extract_fields(result: AnalyzeResult) -> dict:
    """Extract fields using .get() pattern matching official Azure SDK sample."""
    fields = {}
    if result.documents:
        for doc in result.documents:
            if doc.fields:
                for name, field in doc.fields.items():
                    content    = field.get("content")
                    confidence = field.get("confidence")
                    br         = field.get("boundingRegions") or []
                    page       = br[0].get("pageNumber", 1) if br else 1
                    raw_poly = br[0].get("polygon", []) if br else []
                    polygon  = flatten_polygon(raw_poly)
                    fields[name] = {
                        "value":      content,
                        "confidence": round(confidence * 100, 1) if confidence else None,
                        "polygon":    polygon,
                        "page":       page,
                    }
    return fields


def extract_kv_pairs(result: AnalyzeResult) -> list:
    pairs = []
    if hasattr(result, "key_value_pairs") and result.key_value_pairs:
        for kv in result.key_value_pairs:
            key_text = kv.key.content   if kv.key   else ""
            val_text = kv.value.content if kv.value else ""
            conf     = round(kv.confidence * 100, 1) if kv.confidence else None
            key_poly, val_poly, page = [], [], 1
            if kv.key and kv.key.bounding_regions:
                br = kv.key.bounding_regions[0]
                key_poly = flatten_polygon(br.polygon or [])
                page     = br.page_number
            if kv.value and kv.value.bounding_regions:
                br = kv.value.bounding_regions[0]
                val_poly = flatten_polygon(br.polygon or [])
            pairs.append({"key": key_text, "value": val_text, "confidence": conf,
                          "key_polygon": key_poly, "val_polygon": val_poly, "page": page})
    return pairs


def extract_tables(result: AnalyzeResult) -> list:
    tables = []
    if hasattr(result, "tables") and result.tables:
        for t in result.tables:
            cells = {}
            for cell in t.cells:
                cells[(cell.row_index, cell.column_index)] = cell.content
            page = t.bounding_regions[0].page_number if t.bounding_regions else 1
            tables.append({"rows": t.row_count, "cols": t.column_count, "cells": cells, "page": page})
    return tables


