            # ── TAB 5: QUERY ───────────────────────────────────────────────
            with tab_query:
                st.markdown("**Ask a question about the document**")
                query = st.text_input("Query", placeholder='e.g. "What is the total amount?" or "Who is the vendor?"',
                                      label_visibility="collapsed")
                if st.button("🔎 Search", key="query_btn") and query:
                    content_lower = (result.content or "").lower()
                    query_lower   = query.lower()
                    # Simple keyword highlight search
                    keywords = [w for w in query_lower.split() if len(w) > 3]
                    hits = []
                    if hasattr(result, "paragraphs") and result.paragraphs:
                        for para in result.paragraphs:
                            score = sum(1 for kw in keywords if kw in para.content.lower())
                            if score > 0:
                                hits.append((score, para.content, para.bounding_regions[0].page_number if para.bounding_regions else "?"))
                    hits.sort(key=lambda x: -x[0])

                    # Also search in fields
                    field_hits = []
                    for name, f in fields.items():
                        if any(kw in name.lower() or kw in str(f["value"]).lower() for kw in keywords):
                            field_hits.append((name, f["value"], f["confidence"]))

                    if field_hits:
                        st.markdown("**📋 Matching Fields:**")
                        for name, val, conf in field_hits[:5]:
                            st.markdown(f"""
                            <div class='field-card' style='border-left-color:#48bb78'>
                                <div class='field-key'>{name}</div>
                                <div class='field-value'>{val or '—'}</div>
                            </div>
                            """, unsafe_allow_html=True)

                    if hits:
                        st.markdown("**📝 Matching Paragraphs:**")
                        for score, text, pg in hits[:6]:
                            st.markdown(f"""
                            <div class='field-card' style='border-left-color:#ed8936'>
                                <div class='field-key'>Page {pg} · relevance {score}</div>
                                <div class='field-value' style='font-size:13px'>{text[:300]}</div>
                            </div>
                            """, unsafe_allow_html=True)

                    if not field_hits and not hits:
                        st.warning("No matching results found. Try different keywords.")

                # Quick field lookup
                st.markdown("---")
                st.markdown("**⚡ Quick Field Lookup**")
                if fields:
                    selected = st.selectbox("Select a field", list(fields.keys()), label_visibility="collapsed")
                    f = fields[selected]
                    st.markdown(f"""
                    <div class='field-card'>
                        <div class='field-key'>{selected}</div>
                        <div class='field-value' style='font-size:18px'>{f['value'] or '—'}</div>
                        <div class='field-conf'>Confidence: {f['confidence']}% · Page {f['page']}</div>
                    </div>
                    """, unsafe_allow_html=True)

            # ── TAB 6: JSON ────────────────────────────────────────────────
            with tab_json:
                raw = {
                    "model_id":    result.model_id,
                    "api_version": result.api_version if hasattr(result, "api_version") else "",
                    "content":     result.content[:2000] + "..." if result.content and len(result.content) > 2000 else result.content,
                    "fields":      fields,
                    "kv_pairs":    kv_pairs,
                    "tables": [
                        {"rows": t["rows"], "cols": t["cols"], "page": t["page"]}
                        for t in tables
                    ],
                }
                json_str = json.dumps(raw, indent=2, default=str)
                st.code(json_str, language="json")
                st.download_button("⬇ Download Full JSON", json_str, "document_analysis.json", "application/json")

else:
