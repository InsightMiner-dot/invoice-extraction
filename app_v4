        st.warning("Please upload a PDF file first.")
    elif not endpoint or not api_key:
        st.warning("Please enter your Azure endpoint and API key in the sidebar.")
    else:
        pdf_bytes = uploaded_file.read()
        st.session_state.pdf_bytes = pdf_bytes

        doc = fitz.open(stream=pdf_bytes, filetype="pdf")
        st.session_state.page_count = len(doc)
        doc.close()

        with st.spinner("Analyzing document..."):
            try:
                result = run_analysis(endpoint.strip(), api_key.strip(), pdf_bytes, model_id)
                st.session_state.result   = result
                st.session_state.fields   = extract_fields(result)
                st.session_state.kv_pairs = extract_kv_pairs(result)
                st.session_state.tables   = extract_tables(result)
                st.success(f"Done — {len(st.session_state.fields)} fields · "
                           f"{len(st.session_state.kv_pairs)} key-value pairs · "
                           f"{len(st.session_state.tables)} tables")
            except Exception as e:
                st.error(f"Azure API error: {e}")


# ── Main display ───────────────────────────────────────────────────────────────
if st.session_state.pdf_bytes:
    result    = st.session_state.result
    pdf_bytes = st.session_state.pdf_bytes
    fields    = st.session_state.fields or {}
    kv_pairs  = st.session_state.kv_pairs or []
    tables    = st.session_state.tables or []

    left_col, right_col = st.columns(2)

    # ── PDF Preview ──────────────────────────────────────────────────────────
    with left_col:
        st.subheader("Document Preview")
        page_num = 1
        if st.session_state.page_count > 1:
            page_num = st.number_input("Page", min_value=1, max_value=st.session_state.page_count, value=1)

        img = pdf_page_to_pil(pdf_bytes, page_num - 1, render_dpi)

        if highlight_boxes and result:
            # Get page dimensions in inches from the result
            page_w_in, page_h_in = 8.5, 11.0  # fallback defaults
            if result.pages and len(result.pages) >= page_num:
                pg = result.pages[page_num - 1]
                if pg.width:  page_w_in = pg.width
                if pg.height: page_h_in = pg.height

            polys, labels = [], []
            for name, f in fields.items():
                if f["page"] == page_num and f["polygon"]:
                    polys.append(f["polygon"])
                    labels.append(name)
            for kv in kv_pairs:
                if kv["page"] == page_num:
                    if kv["key_polygon"]:
                        polys.append(kv["key_polygon"])
                        labels.append(kv["key"][:15])
                    if kv["val_polygon"]:
                        polys.append(kv["val_polygon"])
                        labels.append("")
            if polys:
                img = draw_bounding_boxes(img, polys, labels, page_w_in, page_h_in)

        st.image(img, use_container_width=True, caption=f"Page {page_num} of {st.session_state.page_count}")

    # ── Tabs ─────────────────────────────────────────────────────────────────
    with right_col:
        if result is None:
            st.info("Run Analysis to see results.")
        else:
            tab_fields, tab_kv, tab_tables, tab_content, tab_query, tab_json = st.tabs([
                "Fields", "Key-Value", "Tables", "Content", "Query", "JSON"
            ])

            # Fields
            with tab_fields:
                st.subheader(f"Fields ({len(fields)})")
                if fields:
                    for name, f in fields.items():
                        conf_str = f" | confidence: {f['confidence']}% | page {f['page']}" if show_confidence and f["confidence"] else ""
                        st.text(f"{name}: {f['value'] or '—'}{conf_str}")
                else:
                    st.info("No structured fields found.")

            # Key-Value
            with tab_kv:
                st.subheader(f"Key-Value Pairs ({len(kv_pairs)})")
                if kv_pairs:
                    for kv in kv_pairs:
                        conf_str = f" | confidence: {kv['confidence']}% | page {kv['page']}" if show_confidence and kv["confidence"] else ""
                        st.text(f"{kv['key']}: {kv['value'] or '—'}{conf_str}")
                else:
                    st.info("No key-value pairs detected.")

            # Tables
            with tab_tables:
                st.subheader(f"Tables ({len(tables)})")
                if tables:
                    for i, t in enumerate(tables):
                        st.write(f"**Table {i+1}** — {t['rows']} rows × {t['cols']} cols (page {t['page']})")
                        data = {}
                        for col in range(t["cols"]):
                            col_key = t["cells"].get((0, col), f"Col {col+1}")
                            data[col_key] = [t["cells"].get((row, col), "") for row in range(1, t["rows"])]
                        df = pd.DataFrame(data)
                        st.dataframe(df, use_container_width=True)
                        st.download_button(f"Download Table {i+1} CSV", df.to_csv(index=False),
                                           f"table_{i+1}.csv", "text/csv", key=f"dl_table_{i}")
                else:
                    st.info("No tables detected.")

            # Content
            with tab_content:
                content_text = result.content or ""
                st.subheader(f"Raw Content ({len(content_text)} chars)")
                page_filter = st.number_input("Filter by page (0 = all)", min_value=0,
                                               max_value=st.session_state.page_count, value=0)
                if page_filter == 0:
                    st.text_area("", value=content_text, height=400)
                else:
                    page_content = []
                    if hasattr(result, "paragraphs") and result.paragraphs:
                        for para in result.paragraphs:
                            if para.bounding_regions and para.bounding_regions[0].page_number == page_filter:
                                page_content.append(para.content)
                    st.text_area("", value="\n\n".join(page_content) or "No content for this page.", height=400)
                st.download_button("Download TXT", content_text, "content.txt", "text/plain")

            # Query
            with tab_query:
                st.subheader("Search Document")
                query = st.text_input("Query", placeholder='e.g. "total amount" or "vendor"')
                if st.button("Search") and query:
                    keywords = [w.lower() for w in query.split() if len(w) > 2]

                    field_hits = [(n, f) for n, f in fields.items()
                                  if any(kw in n.lower() or kw in str(f["value"]).lower() for kw in keywords)]
                    if field_hits:
                        st.write("**Matching Fields:**")
                        for name, f in field_hits:
                            st.text(f"{name}: {f['value']}")

                    para_hits = []
                    if hasattr(result, "paragraphs") and result.paragraphs:
                        for para in result.paragraphs:
                            if any(kw in para.content.lower() for kw in keywords):
                                pg = para.bounding_regions[0].page_number if para.bounding_regions else "?"
                                para_hits.append((pg, para.content))
                    if para_hits:
                        st.write("**Matching Paragraphs:**")
                        for pg, text in para_hits[:8]:
                            st.text(f"[Page {pg}] {text[:200]}")

                    if not field_hits and not para_hits:
                        st.warning("No results found.")

                if fields:
                    st.write("---")
                    st.write("**Quick Field Lookup**")
                    selected = st.selectbox("Pick a field", list(fields.keys()))
                    f = fields[selected]
                    st.write(f"**Value:** {f['value'] or '—'}")
                    if show_confidence and f["confidence"]:
                        st.write(f"**Confidence:** {f['confidence']}%  |  **Page:** {f['page']}")

            # JSON
            with tab_json:
                st.subheader("Raw JSON (original poller result)")
                # Serialize the raw result as-is from the poller using the SDK's built-in method
                json_str = json.dumps(result.as_dict(), indent=2, default=str)
                st.code(json_str, language="json")
                st.download_button("Download JSON", json_str, "result.json", "application/json")
