@st.cache_data(ttl=3600)
def load_master_spend():
    """Dynamically loads the Master Spend USD data from the config folder."""
    try:
        current_script_dir = os.path.dirname(os.path.abspath(__file__))
        config_dir = os.path.join(current_script_dir, "..", "config")
        excel_path = os.path.join(config_dir, "master_spend_usd.xlsx")
        
        if os.path.exists(excel_path):
            df = pd.read_excel(excel_path, dtype={'Invoice number': str, 'unique_key': str})
            if not df.empty and 'unique_key' in df.columns and 'Spend USD' in df.columns:
                df = df.dropna(subset=['unique_key'])
