    def get_sql_agent():
        db = SQLDatabase.from_uri(f"sqlite:///{DB_PATH}")
        llm = AzureChatOpenAI(
            azure_endpoint=AZURE_ENDPOINT,
            api_key=AZURE_API_KEY,
            azure_deployment=AZURE_DEPLOYMENT, 
            api_version=AZURE_API_VERSION
        )

        system_instructions = SystemMessage(content="""
        You are an expert data analyst AI for an invoice database. Follow these rules:
        1. FORMATTING: Return data beautifully as a Markdown table unless asked otherwise.
        2. VARIANCE ZERO RULE: If the user asks for records that "have a variance", strictly exclude zero. You MUST append "WHERE variance != 0" to your SQL query.
        3. CHARTS: If asked for a chart, use the `generate_bar_chart` tool.
        4. EXCEL EXPORT: If the user asks to download or export data, write the SQL query and pass it to the `export_to_excel` tool.
        5. ACCURACY: Do not hallucinate data.
        6. SHOW YOUR WORK: At the very end of your response, you MUST print the exact SQL query you used inside a markdown `sql` code block.
        """)

        toolkit = SQLDatabaseToolkit(db=db, llm=llm)
        agent_executor = create_sql_agent(
            llm=llm,
            toolkit=toolkit,
            extra_tools=[generate_bar_chart, export_to_excel], 
            verbose=True,
            agent_type="openai-tools",
            extra_prompt_messages=[system_instructions, MessagesPlaceholder(variable_name="history")] 
        )
        return agent_executor

    if AZURE_ENDPOINT and AZURE_API_KEY:
        agent_executor = get_sql_agent()
        
        st.markdown("### ⚡ Quick Queries")
        q_cols = st.columns(5)
        quick_questions = [
            "Top 10 suppliers that have a variance",
            "Show me a bar chart of the top 5 vendors by total amount",
            "Export the deletion logs for the past week",
            "Which origins are missing for our top vendor?",
            "What is the average extraction time?"
        ]

        if 'active_prompt' not in st.session_state:
            st.session_state.active_prompt = None

        for i, col in enumerate(q_cols):
            if col.button(quick_questions[i], key=f"btn_{i}"):
                st.session_state.active_prompt = quick_questions[i]

        if len(msgs.messages) == 0:
            msgs.add_ai_message("Hello! I'm ready to analyze your invoices.")

        chatbot_with_memory = RunnableWithMessageHistory(
            agent_executor,
            lambda session_id: msgs,
            input_messages_key="input",
            history_messages_key="history",
        )

        for msg in msgs.messages:
            st.chat_message(msg.type).write(msg.content)

        user_input = st.chat_input("Ask for an analysis or a chart...")
        prompt = user_input or st.session_state.active_prompt

        if prompt:
            st.session_state.active_prompt = None
            st.chat_message("human").write(prompt)

            if os.path.exists("chart.png"): os.remove("chart.png")
            if os.path.exists("export.xlsx"): os.remove("export.xlsx")

            with st.chat_message("ai"):
                with st.spinner("Analyzing database..."):
                    try:
                        session_id = "streamlit_session_1"
                        response = chatbot_with_memory.invoke(
                            {"input": prompt},
                            config={"configurable": {"session_id": session_id}}
                        )
                        ai_text = response["output"]
                        st.write(ai_text)
                        
                        if os.path.exists("chart.png"): st.image("chart.png")
                        
                        if os.path.exists("export.xlsx"):
                            with open("export.xlsx", "rb") as f:
                                st.download_button(
                                    label="📥 Download Excel File",
                                    data=f,
                                    file_name="invoice_data_export.xlsx",
                                    mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
                                )
                        
                        row_id = log_interaction(session_id, prompt, ai_text)
                        st.session_state.last_row_id = row_id

                    except Exception as e:
                        st.error(f"An error occurred: {e}")

        if 'last_row_id' in st.session_state:
            st.write("---")
            f_col1, f_col2, f_col3 = st.columns([1, 1, 10])
            with f_col1:
                if st.button("👍 Good", key="thumb_up"):
                    update_feedback(st.session_state.last_row_id, "thumbs_up")
                    st.toast("Feedback recorded!")
            with f_col2:
                if st.button("👎 Bad", key="thumb_down"):
                    update_feedback(st.session_state.last_row_id, "thumbs_down")
                    st.toast("Feedback recorded!")
    else:
        st.warning("⚠️ Azure credentials missing. Check your `.env` file to use the Chat feature.")
