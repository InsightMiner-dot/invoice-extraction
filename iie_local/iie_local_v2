        current_batch_issues = st.session_state.audit_df[
            st.session_state.audit_df['origin'].isin(batch_missing_flags) | st.session_state.audit_df['origin'].isna() |
            st.session_state.audit_df['destination'].isin(batch_missing_flags) | st.session_state.audit_df['destination'].isna()
        ].copy()

        if not current_batch_issues.empty:
            review_df = current_batch_issues[['file_name', 'raw_vendor', 'origin', 'final_origin', 'destination', 'final_destination']]
            edited_routes = st.data_editor(
                review_df,
                width='stretch',
                column_config={
                    "file_name": st.column_config.TextColumn("File", disabled=True), "raw_vendor": st.column_config.TextColumn("Raw Vendor", disabled=True),
                    "origin": st.column_config.TextColumn("Raw Origin", disabled=True), "final_origin": st.column_config.TextColumn("✅ Approved Origin"),
                    "destination": st.column_config.TextColumn("Raw Dest", disabled=True), "final_destination": st.column_config.TextColumn("✅ Approved Dest")
                }
            )
            
            if st.button("💾 Save Approved Routes to Memory"):
                for index, row in edited_routes.iterrows():
                    fname = row['file_name']
                    if pd.notna(row['final_origin']) and str(row['final_origin']).strip() != "":
                        st.session_state.audit_df.loc[index, 'origin'] = row['final_origin']
                        st.session_state.audit_df.loc[index, 'final_origin'] = row['final_origin']
                        for detail in st.session_state.extraction_details:
                            if detail['File Name'] == fname: detail['Origin'] = row['final_origin']
                        for summary in st.session_state.extraction_summary:
                            if summary['File Name'] == fname: summary['Origin'] = row['final_origin']
                            
                    if pd.notna(row['final_destination']) and str(row['final_destination']).strip() != "":
                        st.session_state.audit_df.loc[index, 'destination'] = row['final_destination']
                        st.session_state.audit_df.loc[index, 'final_destination'] = row['final_destination']
                        for detail in st.session_state.extraction_details:
                            if detail['File Name'] == fname: detail['Destination'] = row['final_destination']
                        for summary in st.session_state.extraction_summary:
                            if summary['File Name'] == fname: summary['Destination'] = row['final_destination']
                
                rebuild_excel_from_state(list(custom_fields_dict.keys()))
                st.success("Routes successfully updated and Excel dynamically rebuilt!")
                time.sleep(1.5)
                st.rerun()
        else:
            st.info("No missing routing addresses found in the current batch!")

        st.divider()
        with st.expander("Side-by-Side Exception Audit Mode", expanded=False):
            files_with_issues = batch_df[(batch_df['status'] != 'PASS') | (batch_df['row_warnings'] != 'N/A')]['file_name'].unique()
            if len(files_with_issues) > 0:
                selected_audit_file = st.selectbox("Select a flagged file to audit:", files_with_issues)
                if selected_audit_file and selected_audit_file in st.session_state.uploaded_files_cache:
                    audit_row = batch_df[batch_df['file_name'] == selected_audit_file].iloc[0]
                    if audit_row['status'] == 'PASS': st.success(f"Overall Status: PASS for {selected_audit_file}")
                    else: st.error(f"Overall Status: FAIL | Reasons: {audit_row['reason_for_review']}")
                    
                    if audit_row.get('hallucination_alert', False): st.error("🚨 HALLUCINATION WARNING: The extracted invoice number does not exist in the raw PDF text.")
                    if audit_row.get('row_warnings', 'N/A') != 'N/A': st.warning(f"⚠️ Row Math Warning: {audit_row['row_warnings']}")

                    col_pdf, col_data = st.columns([1.5, 1])
                    with col_pdf:
                        st.markdown("**Original Document**")
                        display_pdf(st.session_state.uploaded_files_cache[selected_audit_file])
                    with col_data:
                        st.markdown("**Key Extracted Data**")
                        st.text_input("Raw Vendor", value=audit_row['raw_vendor'], disabled=True)
                        st.text_input("Invoice Number", value=audit_row['invoice_number'], disabled=True)
                        st.text_input("Origin", value=audit_row['origin'], disabled=True)
                        st.text_input("Destination", value=audit_row['destination'], disabled=True)
                        st.text_input("Extracted Total", value=f"${audit_row['extracted_total']}", disabled=True)
                        st.text_input("UOM(s) Found", value=audit_row.get('uoms', 'N/A'), disabled=True)
                        
                        st.markdown("**Master DB Validation**")
                        st.text_input("In Master DB?", value=audit_row.get('in_master', 'No'), disabled=True)
                        st.text_input("Master Spend USD", value=f"${audit_row.get('master_spend', 0.0)}", disabled=True)
                        st.text_input("Master Variance", value=f"${audit_row.get('master_variance', 0.0)}", disabled=True)
            else:
                st.success("No files require manual auditing!")
                
        # --- FINAL REVIEW & EXPORT SECTION ---
        st.divider()
        st.header("🏁 Final Review & Export")
        if st.button("🔄 Run Final Master DB Comparison & Generate Report", type="primary"):
            master_spend_dict = load_master_spend()
            for index, row in st.session_state.audit_df.iterrows():
                fname = row['file_name']
                inv_num = row['invoice_number']
                calc_total = row['calculated_sum']
                vendor_to_check = row['clean_vendor'] if pd.notna(row['clean_vendor']) and str(row['clean_vendor']).strip() != "" else row['raw_vendor']
                
                in_master = "No"
                master_spend = 0.0
                master_variance = 0.0
                
                if vendor_to_check and inv_num and str(inv_num).upper() != "N/A":
                    master_key = f"{str(vendor_to_check).strip()}_{str(inv_num).strip()}"
                    if master_key in master_spend_dict:
                        in_master = "Yes"
                        master_spend = master_spend_dict[master_key]
                        master_variance = round(calc_total - master_spend, 2)
                        
                st.session_state.audit_df.loc[index, 'in_master'] = in_master
                st.session_state.audit_df.loc[index, 'master_spend'] = master_spend
                st.session_state.audit_df.loc[index, 'master_variance'] = master_variance
                
                for summary in st.session_state.extraction_summary:
                    if summary['File Name'] == fname:
                        summary['In Master DB'] = in_master
                        summary['Master Spend USD'] = master_spend
                        summary['Master Variance'] = master_variance
                        
            rebuild_excel_from_state(list(custom_fields_dict.keys()))
            st.session_state.show_final_report = True
            st.success("Comparison complete! Excel file regenerated.")
            time.sleep(1)
            st.rerun()

        if st.session_state.get('show_final_report', False):
            st.subheader("📊 Final QC Summary Report")
            qc_display_df = pd.DataFrame(st.session_state.extraction_summary)
            
            st.dataframe(
                qc_display_df, width='stretch', hide_index=True,
                column_config={
                    "Extracted Total": st.column_config.NumberColumn(format="$%.2f"),
                    "Calculated Sum": st.column_config.NumberColumn(format="$%.2f"),
                    "Variance": st.column_config.NumberColumn(format="$%.2f"),
                    "Master Spend USD": st.column_config.NumberColumn(format="$%.2f"),
                    "Master Variance": st.column_config.NumberColumn(format="$%.2f")
                }
            )
            
            st.download_button(
                label="📥 Download Final Extract Data (Excel)",
                data=st.session_state.extraction_excel,
                file_name=f"Final_Invoice_Extraction_{datetime.now().strftime('%Y-%m-%d_%H-%M-%S')}.xlsx",
                mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                type="primary"
            )
