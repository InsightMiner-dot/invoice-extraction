    def init_history_db():
        conn = sqlite3.connect("chat_history.sqlite")
        c = conn.cursor()
        c.execute('''CREATE TABLE IF NOT EXISTS interactions
                    (id INTEGER PRIMARY KEY AUTOINCREMENT,
                    session_id TEXT,
                    timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
                    user_query TEXT,
                    ai_response TEXT,
                    feedback TEXT)''')
        conn.commit()
        conn.close()

    def log_interaction(session_id, user_query, ai_response):
        conn = sqlite3.connect("chat_history.sqlite")
        c = conn.cursor()
        c.execute("INSERT INTO interactions (session_id, user_query, ai_response) VALUES (?, ?, ?)", 
                (session_id, user_query, ai_response))
        row_id = c.lastrowid
        conn.commit()
        conn.close()
        return row_id

    def update_feedback(row_id, feedback_value):
        conn = sqlite3.connect("chat_history.sqlite")
        c = conn.cursor()
        c.execute("UPDATE interactions SET feedback = ? WHERE id = ?", (feedback_value, row_id))
        conn.commit()
        conn.close()

