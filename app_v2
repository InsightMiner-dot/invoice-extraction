with tab_extract:

    uploaded_files = st.file_uploader(
        "Upload invoice PDFs",
        type=["pdf"],
        accept_multiple_files=True,
        help="Upload one or many PDFs. Re-uploading a file replaces its previous results.",
    )

    if uploaded_files:
        st.write(f"**{len(uploaded_files)} file(s) queued:**")
        for uf in uploaded_files:
            sz   = round(len(uf.getvalue()) / 1024, 1)
            reup = (
                uf.name in st.session_state.file_hashes
                and st.session_state.file_hashes[uf.name] == file_hash(uf.getvalue())
            )
            note = "  _(re-upload — will replace existing rows)_" if reup else ""
            st.write(f"- `{uf.name}` — {sz} KB{note}")

    st.divider()

    can_run = bool(uploaded_files and config and di_ok and oai_ok)
    run_btn = st.button("▶ Run extraction", type="primary", disabled=not can_run)

    if not can_run and uploaded_files:
        if not (di_ok and oai_ok):
            st.error("Azure credentials not set. Check the sidebar.")
        if not config:
            st.error("fields_config.json not loaded. Check the sidebar path.")

    # ── BATCH EXECUTION ───────────────────────────────────────────────────────
    if run_btn and uploaded_files and config:
        schema          = build_extraction_schema(config)
        file_bytes_map  = {uf.name: uf.getvalue() for uf in uploaded_files}

        # Remove stale rows for files being re-processed
        reprocess = set(file_bytes_map)
        st.session_state.all_rows = [
            r for r in st.session_state.all_rows if r.get("File Name") not in reprocess
        ]
        st.session_state.results = [
            r for r in st.session_state.results if r.get("file") not in reprocess
        ]

        overall_bar  = st.progress(0, text="Starting batch…")
        log_expander = st.expander("Live log", expanded=True)
        log_area     = log_expander.empty()
        log_q: list[str] = []

        new_rows, new_results = [], []
        completed = 0
        futures: dict[concurrent.futures.Future, str] = {}

        with concurrent.futures.ThreadPoolExecutor(max_workers=max_workers) as pool:
            for uf in uploaded_files:
                fut = pool.submit(
                    process_one_pdf,
                    uf.getvalue(), uf.name,
                    config, schema, threshold, log_q,
                )
                futures[fut] = uf.name

            pending = set(futures)
            while pending:
                done, pending = concurrent.futures.wait(
                    list(pending), timeout=0.5,
                    return_when=concurrent.futures.FIRST_COMPLETED,
                )
                for fut in done:
                    fname = futures[fut]
                    completed += 1
                    overall_bar.progress(
                        completed / len(uploaded_files),
                        text=f"Completed {completed}/{len(uploaded_files)}: {fname}",
                    )
                    try:
                        rows, segs = fut.result()
                        new_rows.extend(rows)
                        new_results.extend(segs)
                        st.session_state.file_hashes[fname] = file_hash(file_bytes_map[fname])
                    except Exception as e:
                        new_results.append({"file": fname, "status": "error", "error": str(e)})

                if log_q:
                    log_area.text("\n".join(log_q[-25:]))

        # Final log flush
        if log_q:
            log_area.text("\n".join(log_q))

        st.session_state.all_rows.extend(new_rows)
        st.session_state.results.extend(new_results)

        overall_bar.progress(1.0, text="Batch complete!")
        time.sleep(0.3)
        overall_bar.empty()
        st.rerun()

    # ── BATCH SUMMARY (shown after extraction) ────────────────────────────────
    if st.session_state.results:
        st.divider()
        st.subheader("Batch summary")

        results = st.session_state.results
        c1, c2, c3, c4 = st.columns(4)
        c1.metric("Total segments",  len(results))
        c2.metric("✅ Success",      sum(1 for r in results if r.get("status") == "success"))
        c3.metric("⚠️ Needs review", sum(1 for r in results if r.get("status") == "needs_review"))
        c4.metric("❌ Errors",       sum(1 for r in results if r.get("status") == "error"))

        # One-row-per-file summary table
        by_file: dict[str, list] = defaultdict(list)
        for r in results:
            by_file[r["file"]].append(r)

        summary = []
        for fname, segs in by_file.items():
            confs = [s["confidence"] for s in segs if s.get("confidence")]
            any_err    = any(s.get("status") == "error"        for s in segs)
            any_review = any(s.get("status") == "needs_review" for s in segs)
            summary.append({
                "File":           fname,
                "Segments":       len(segs),
                "Pages":          ", ".join(str(p) for s in segs for p in s.get("pages", [])),
                "Status":         "❌ error" if any_err else "⚠️ review" if any_review else "✅ success",
                "Avg confidence": f"{sum(confs)/len(confs):.0%}" if confs else "—",
                "Rows":           sum(s.get("rows", 0) for s in segs),
                "Multi-invoice":  "⚠️ Yes" if any(s.get("multi_invoice") for s in segs) else "No",
            })
        st.dataframe(pd.DataFrame(summary), use_container_width=True, hide_index=True)

        # Per-segment detail in expanders
        st.subheader("Segment details")
        for fname, segs in by_file.items():
            with st.expander(f"📄 {fname}  ({len(segs)} segment(s))"):
                for seg in segs:
                    status = seg.get("status", "error")
                    conf   = seg.get("confidence", 0) or 0
                    icon   = {"success": "✅", "needs_review": "⚠️", "error": "❌"}.get(status, "❓")

                    st.write(
                        f"{icon} **Split #{seg.get('split_num', 1)}**  ·  "
                        f"pages `{seg.get('pages', [])}`  ·  "
                        f"inv# `{seg.get('detected_inv', '—')}`  ·  "
                        f"conf `{conf:.0%}`  ·  "
                        f"`{seg.get('rows', 0)}` rows"
                    )
                    for issue in seg.get("issues", []):
                        st.caption(f"   ⚠️ {issue}")
                    if seg.get("error"):
                        st.error(seg["error"])
                    if seg.get("extracted"):
                        with st.expander("Raw extracted JSON", expanded=False):
                            st.json(seg["extracted"])
                    st.divider()


# ─────────────────────────────────────────────────────────────────────────────
# TAB 2 — RESULTS
# ─────────────────────────────────────────────────────────────────────────────

with tab_results:
    if not st.session_state.all_rows:
        st.info("No data yet. Extract invoices in the Extract tab first.")
    else:
        csv_cols = build_csv_columns(config) if config else list(st.session_state.all_rows[0].keys())
        df = pd.DataFrame(st.session_state.all_rows)

        # Reorder columns to match config order
        ordered = [c for c in csv_cols if c in df.columns]
        extra   = [c for c in df.columns if c not in ordered]
        df = df[ordered + extra]

        n_files = df["File Name"].nunique() if "File Name" in df.columns else "?"
        st.subheader(f"Extracted data — {len(df)} rows from {n_files} file(s)")

        # Filters
        with st.expander("🔍 Filters", expanded=False):
            fc1, fc2, fc3, fc4 = st.columns(4)
            with fc1:
                if "File Name" in df.columns:
                    ff = st.multiselect("File name", sorted(df["File Name"].unique()))
                    if ff:
                        df = df[df["File Name"].isin(ff)]
            with fc2:
                if "Invoice Split #" in df.columns:
                    sf = st.multiselect("Invoice split #", sorted(df["Invoice Split #"].dropna().unique()))
                    if sf:
                        df = df[df["Invoice Split #"].isin(sf)]
            with fc3:
                if "Page(s)" in df.columns:
                    pg = st.text_input("Page number contains", placeholder="e.g. 2")
                    if pg:
                        df = df[df["Page(s)"].astype(str).str.contains(pg.strip())]
            with fc4:
                if "Description" in df.columns:
                    kw = st.text_input("Description contains", placeholder="keyword")
                    if kw:
                        df = df[df["Description"].str.contains(kw, case=False, na=False)]

        st.dataframe(df, use_container_width=True, height=420, hide_index=True)

        # Downloads
        st.subheader("Download")
        dc1, dc2, dc3 = st.columns(3)
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")

        with dc1:
            st.download_button(
                "⬇️ CSV",
                data=to_csv_bytes(df.to_dict("records"), list(df.columns)),
                file_name=f"invoices_{ts}.csv",
                mime="text/csv",
                use_container_width=True,
            )
        with dc2:
            buf = io.BytesIO()
            df.to_excel(buf, index=False, engine="openpyxl")
            st.download_button(
                "⬇️ Excel",
                data=buf.getvalue(),
                file_name=f"invoices_{ts}.xlsx",
                mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                use_container_width=True,
            )
        with dc3:
            st.download_button(
                "⬇️ JSON (raw)",
                data=json.dumps(st.session_state.results, indent=2, default=str).encode(),
                file_name=f"invoices_{ts}.json",
                mime="application/json",
                use_container_width=True,
            )

        # Needs-review section
        review_segs = [r for r in st.session_state.results if r.get("status") == "needs_review"]
        if review_segs:
            st.divider()
            st.subheader(f"⚠️ Needs review — {len(review_segs)} segment(s)")
            for r in review_segs:
                pages = ", ".join(f"p{p}" for p in r.get("pages", []))
                with st.expander(
                    f"{r['file']} — split #{r.get('split_num', 1)} "
                    f"({pages}) — conf {r.get('confidence', 0):.0%}"
                ):
                    for issue in r.get("issues", []):
                        st.caption(f"• {issue}")
                    if r.get("extracted"):
                        st.json(r["extracted"])


