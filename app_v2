def load_config(path: str) -> dict:
    with open(path) as f:
        return json.load(f)


def build_csv_columns(config: dict) -> list[str]:
    header_cols = [v["csv_column"] for v in config["header_fields"].values()]
    li_cols     = [v["csv_column"] for v in config["line_item_fields"].values()]
    # File Name | Page(s) | Invoice Split # | <rest of header> | <line items> | Confidence
    return header_cols[:1] + ["Page(s)", "Invoice Split #"] + header_cols[1:] + li_cols + ["Confidence"]


def build_extraction_schema(config: dict) -> dict:
    header_schema = {
        k: {
            "type": "string or null",
            "aliases_to_look_for": v["aliases"],
            "csv_column": v["csv_column"],
        }
        for k, v in config["header_fields"].items()
        if not v.get("source") == "system"
    }
    li_schema = {
        k: {
            "type": "string or null",
            "aliases_to_look_for": v["aliases"],
            "csv_column": v["csv_column"],
        }
        for k, v in config["line_item_fields"].items()
    }
    li_schema["page_number"] = {
        "type": "integer",
        "description": "1-based page number where this line item row appears",
    }
    return {
        "header": header_schema,
        "line_items": {
            "_description": (
                "All charge rows. Every tax/GST/CGST/SGST/IGST/surcharge/cess/duty "
                "MUST be its own separate line_item. Set page_number on every item."
            ),
            "_tax_labels": config["tax_line_items"]["known_tax_labels"],
            "fields": li_schema,
        },
    }


def file_hash(data: bytes) -> str:
    return hashlib.md5(data).hexdigest()


# ══════════════════════════════════════════════════════════════════════════════
# AZURE DI — page-aware layout extraction
# ══════════════════════════════════════════════════════════════════════════════

def extract_layout_by_page(pdf_bytes: bytes) -> tuple[list[dict], int]:
    poller = DI_CLIENT.begin_analyze_document("prebuilt-layout", pdf_bytes)
    result = poller.result()
    total  = len(result.pages)

    page_lines: dict[int, list] = defaultdict(list)
    for page in result.pages:
        for line in page.lines:
            page_lines[page.page_number].append(line.content)

    page_tables: dict[int, list] = defaultdict(list)
    for t_idx, table in enumerate(result.tables):
        rows: dict[int, dict] = {}
        first_page = 1
        for cell in table.cells:
            if cell.bounding_regions:
                first_page = cell.bounding_regions[0].page_number
            rows.setdefault(cell.row_index, {})[cell.column_index] = cell.content
        t_lines = [
            " | ".join(rows[r].get(c, "").strip() for c in sorted(rows[r]))
            for r in sorted(rows)
        ]
        page_tables[first_page].append((t_idx + 1, t_lines))

    pages_data = []
    for pnum in sorted(page_lines):
        parts = [f"=== PAGE {pnum} ==="]
        parts.extend(page_lines[pnum])
        for t_num, t_lines in page_tables.get(pnum, []):
            parts.append(f"--- Table {t_num} ---")
            parts.extend(t_lines)
        pages_data.append({"page_num": pnum, "text": "\n".join(parts)})

    return pages_data, total


# ══════════════════════════════════════════════════════════════════════════════
# MULTI-INVOICE DETECTION
# ══════════════════════════════════════════════════════════════════════════════

INV_PATTERNS = [
    r'\b(?:invoice|inv|bill)\s*(?:no|num|number|#|:)?\s*[:\-]?\s*([A-Z0-9][A-Z0-9\-\/]{2,20})\b',
    r'\b([A-Z]{2,5}[-\/]?\d{4,12})\b',
    r'\b(INV[-\/]?\d{3,12})\b',
]


def detect_invoice_per_page(pages_data: list[dict]) -> dict[int, str | None]:
    out = {}
    for p in pages_data:
        found = None
        for pat in INV_PATTERNS:
            m = re.search(pat, p["text"], re.IGNORECASE)
            if m:
                found = m.group(1).upper().strip()
                break
        out[p["page_num"]] = found
    return out


def group_pages_into_segments(page_inv_map: dict[int, str | None]) -> list[dict]:
    """
    Same inv# → extend current segment.
    New inv# → close current, start new.
    No inv# detected → continuation of current segment.
    """
    groups, curr_inv, curr_pages = [], None, []
    for pnum in sorted(page_inv_map):
        detected = page_inv_map[pnum]
        if detected is None:
            curr_pages.append(pnum)
        elif detected == curr_inv:
            curr_pages.append(pnum)
        else:
            if curr_pages:
                groups.append({"invoice_number": curr_inv, "pages": curr_pages})
            curr_inv, curr_pages = detected, [pnum]
    if curr_pages:
        groups.append({"invoice_number": curr_inv, "pages": curr_pages})
    return groups


# ══════════════════════════════════════════════════════════════════════════════
# LLM EXTRACTION — with retry on rate limit
# ══════════════════════════════════════════════════════════════════════════════

SYSTEM_PROMPT = """You are a strict invoice data extraction engine.

RULES:
1. ONLY extract values explicitly present as text in the document.
2. NEVER infer, calculate, guess, or assume any value.
3. Return null for any field not found — never guess.
4. Extract EVERY line row as a separate object in line_items.
5. TAX RULE: Any line with tax/GST/CGST/SGST/IGST/VAT/surcharge/cess/duty
   → its own separate line_item with exact label as description.
6. Set page_number (int, 1-based) on every line_item.
7. Return ONLY valid JSON. No markdown, no explanation."""


def extract_with_llm(
    segment_text: str, schema: dict, page_hint: str, max_retries: int = 3
) -> dict:
    user_msg = (
        f"Extract all invoice data from pages: {page_hint}\n\n"
        f"Return JSON matching this structure:\n{json.dumps(schema, indent=2)}\n\n"
        f"Rules:\n"
        f"- null for missing fields (not empty string).\n"
        f"- Tax/GST/CGST/SGST/IGST/surcharge → separate line_item rows only.\n"
        f"- page_number on every line item.\n"
        f"- Do NOT infer. Extract only text present on the document.\n\n"
        f"=== DOCUMENT PAGES ===\n{segment_text}"
    )
    for attempt in range(1, max_retries + 1):
        try:
            resp = LLM_CLIENT.chat.completions.create(
                model=os.getenv("AZURE_OPENAI_DEPLOYMENT", "gpt-4o-mini"),
                messages=[
                    {"role": "system", "content": SYSTEM_PROMPT},
                    {"role": "user",   "content": user_msg},
                ],
                temperature=0,
                max_tokens=4096,
                response_format={"type": "json_object"},
            )
            return json.loads(resp.choices[0].message.content)
        except RateLimitError:
            if attempt < max_retries:
                time.sleep(2 ** attempt)   # 2s, 4s, 8s
            else:
                raise
        except json.JSONDecodeError:
            if attempt < max_retries:
                time.sleep(1)
            else:
                raise


# ══════════════════════════════════════════════════════════════════════════════
# VALIDATION + CONFIDENCE SCORING
# ══════════════════════════════════════════════════════════════════════════════

def validate_and_score(
    extracted: dict, config: dict,
    file_name: str, pages: list[int], split_num: int,
) -> tuple[dict, float, list[str]]:
    issues, checks = [], 0
    header     = extracted.get("header", {})
    line_items = extracted.get("line_items", [])

    for key, meta in config["header_fields"].items():
        if meta.get("source") == "system":
            continue
        if meta.get("required"):
            checks += 1
            val = header.get(key)
            if not val or str(val).strip().lower() in ("null", "none", ""):
                issues.append(f"Missing required: {meta['csv_column']}")

    checks += 1
    if not line_items:
        issues.append("No line items extracted")

    try:
        total_str = header.get("total_invoice_amount")
        if total_str and line_items:
            checks += 1
            total_val = float(re.sub(r"[^\d.]", "", str(total_str)))
            line_sum  = sum(
                float(re.sub(r"[^\d.]", "", str(li.get("amount") or "")))
                for li in line_items
                if li.get("amount") and str(li.get("amount")).strip() not in ("", "null", "None")
            )
            if line_sum > 0 and abs(line_sum - total_val) / max(total_val, 1) > 0.05:
                issues.append(f"Amount mismatch: lines={line_sum:.2f} total={total_val:.2f}")
    except (ValueError, TypeError):
        pass

    confidence = round(1 - (len(issues) / max(checks, 1)), 2)
    header["file_name"] = file_name
    header["pages"]     = ",".join(str(p) for p in sorted(pages))
    header["split_num"] = str(split_num)
    return extracted, confidence, issues


# ══════════════════════════════════════════════════════════════════════════════
# FLATTEN → CSV ROWS
# ══════════════════════════════════════════════════════════════════════════════

def flatten_to_rows(extracted: dict, config: dict, confidence: float) -> list[dict]:
    """One CSV row per line item. Header fields repeat on every row."""
    header     = extracted.get("header", {})
    line_items = extracted.get("line_items", [])

    # Build header portion of every row
    base = {}
    for key, meta in config["header_fields"].items():
        val = header.get(key)
        base[meta["csv_column"]] = (
            "" if val is None or str(val).lower() in ("null", "none") else str(val).strip()
        )
    base["Page(s)"]         = header.get("pages", "")
    base["Invoice Split #"] = header.get("split_num", "1")
    base["Confidence"]      = str(confidence)

    if not line_items:
        row = dict(base)
        for meta in config["line_item_fields"].values():
            row[meta["csv_column"]] = ""
        return [row]

    rows = []
    for li in line_items:
        row = dict(base)
        # Use line-item page number if LLM provided it (more precise than invoice range)
        li_page = li.get("page_number")
        if li_page and str(li_page).strip() not in ("", "null", "None", "0"):
            row["Page(s)"] = str(li_page)
        for key, meta in config["line_item_fields"].items():
            val = li.get(key)
            row[meta["csv_column"]] = (
                "" if val is None or str(val).lower() in ("null", "none") else str(val).strip()
            )
        rows.append(row)
    return rows


def to_csv_bytes(rows: list[dict], columns: list[str]) -> bytes:
    buf = io.StringIO()
    w   = csv.DictWriter(buf, fieldnames=columns, extrasaction="ignore")
    w.writeheader()
    w.writerows(rows)
    return buf.getvalue().encode()


# ══════════════════════════════════════════════════════════════════════════════
# SINGLE PDF PROCESSOR  (runs inside a thread — fully isolated)
# ══════════════════════════════════════════════════════════════════════════════

def process_one_pdf(
    pdf_bytes: bytes,
    file_name: str,
    config: dict,
    schema: dict,
    threshold: float,
    log_q: list,       # thread-safe via GIL on list.append
) -> tuple[list[dict], list[dict]]:
    """
    Returns (csv_rows, segment_results).
    All exceptions caught — never propagates.
    """

    def log(msg: str, icon: str = "·"):
        log_q.append(f"{icon}  [{file_name}] {msg}")

    all_rows, seg_results = [], []

    try:
        log("Azure DI: extracting layout…", "📄")
        pages_data, total_pages = extract_layout_by_page(pdf_bytes)
        log(f"{total_pages} page(s) · {sum(len(p['text']) for p in pages_data):,} chars", "✓")

        log("Detecting invoice numbers per page…", "🔍")
        page_inv_map = detect_invoice_per_page(pages_data)
        unique_invs  = {v for v in page_inv_map.values() if v}
        log(f"Invoice numbers found: {unique_invs or '(none — treating as one invoice)'}", "✓")

        groups     = group_pages_into_segments(page_inv_map)
        multi      = len(groups) > 1
        page_text  = {p["page_num"]: p["text"] for p in pages_data}

        if multi:
            log(f"⚠️ {len(groups)} invoice segments detected in this PDF", "⚠️")

        for idx, group in enumerate(groups, 1):
            seg_pages    = group["pages"]
            detected_inv = group.get("invoice_number", "—")
            page_hint    = f"pages {','.join(str(p) for p in seg_pages)} of {total_pages}"

            log(f"Segment {idx}/{len(groups)}: {page_hint} | inv# {detected_inv}", "🤖")
            seg_text = "\n\n".join(page_text[p] for p in seg_pages if p in page_text)

            try:
                extracted = extract_with_llm(seg_text, schema, page_hint)
                extracted, conf, issues = validate_and_score(
                    extracted, config, file_name, seg_pages, idx
                )
                rows   = flatten_to_rows(extracted, config, conf)
                status = "success" if conf >= threshold else "needs_review"
                all_rows.extend(rows)

                log(
                    f"Segment {idx} → {status} | conf={conf:.0%} | {len(rows)} row(s)",
                    "✅" if status == "success" else "⚠️",
                )
                seg_results.append({
                    "file":          file_name,
                    "split_num":     idx,
                    "total_splits":  len(groups),
                    "pages":         seg_pages,
                    "detected_inv":  detected_inv,
                    "status":        status,
                    "confidence":    conf,
                    "issues":        issues,
                    "rows":          len(rows),
                    "extracted":     extracted,
                    "multi_invoice": multi,
                })

            except Exception as seg_err:
                log(f"Segment {idx} failed: {seg_err}", "❌")
                seg_results.append({
                    "file":          file_name,
                    "split_num":     idx,
                    "total_splits":  len(groups),
                    "pages":         seg_pages,
                    "detected_inv":  detected_inv,
                    "status":        "error",
                    "error":         str(seg_err),
                    "multi_invoice": multi,
                })

    except Exception as file_err:
        log(f"File-level failure: {file_err}", "❌")
        seg_results.append({"file": file_name, "status": "error", "error": str(file_err)})

    log(f"Done — {len(all_rows)} total rows", "🏁")
    return all_rows, seg_results


