        st.code("""{
  "po_number": {
    "csv_column": "PO Number",
    "aliases": ["po number", "purchase order", "po #"],
    "required": false
  }
}""", language="json")

        st.write("**Add a new tax label (auto-extracted as separate line item):**")
        st.code('"known_tax_labels": ["gst", "cgst", "your_new_tax_here"]', language="json")

    else:
        st.error(f"Could not load config from `{config_path}`. Check the path in the sidebar.")
