        # Show previews
        for fi in di_only_info:
            preview_key = f"di_preview_{fi['name']}"
            if preview_key in st.session_state:
                di_out = st.session_state[preview_key]
                with st.expander(f"📄 DI Output — {fi['name']}", expanded=False):
                    st.markdown("**Extracted Header Fields:**")
                    hf_rows = [
                        {"Label": k, "Value": v["value"], "Conf": f"{v['confidence']*100:.0f}%"}
