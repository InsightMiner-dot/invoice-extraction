def load_registry():
    if os.path.exists(REGISTRY_FILE):
        with open(REGISTRY_FILE) as f:
            return json.load(f)
    return {}

def save_registry(r):
    with open(REGISTRY_FILE, "w") as f:
        json.dump(r, f, indent=2)

def load_keywords():
    if os.path.exists(KEYWORDS_FILE):
        with open(KEYWORDS_FILE) as f:
            return json.load(f).get("keywords", DEFAULT_CHARGE_KEYWORDS)
    return list(DEFAULT_CHARGE_KEYWORDS)

def save_keywords(kws):
    with open(KEYWORDS_FILE, "w") as f:
        json.dump({"keywords": kws}, f, indent=2)

def get_llm_client():
    return AzureOpenAI(
        azure_endpoint=AZURE_OPENAI_ENDPOINT,
        api_key=AZURE_OPENAI_KEY,
        api_version=AZURE_OPENAI_API_VERSION,
    )

def to_float(v):
    if v is None:
        return None
    try:
        return float(re.sub(r"[^\d.\-]", "", str(v)))
    except Exception:
        return None

def is_charge_row(text: str, keywords: list) -> bool:
    t = str(text).lower().strip()
    return any(kw.lower() in t for kw in keywords)

# ── Azure DI ──────────────────────────────────────────────────────────────────

def run_azure_di(file_bytes: bytes) -> dict:
    client = DocumentIntelligenceClient(DI_ENDPOINT, AzureKeyCredential(DI_KEY))
    poller = client.begin_analyze_document(
        "prebuilt-layout",
        body=file_bytes,
        content_type="application/octet-stream"
    )
    result = poller.result()

    output = {
        "raw_text":      result.content or "",
        "header_fields": {},
        "tables":        []
    }

    if result.key_value_pairs:
        for kv in result.key_value_pairs:
            if kv.key and kv.value:
                output["header_fields"][kv.key.content.strip()] = {
                    "value":      kv.value.content.strip(),
                    "confidence": round(kv.confidence or 0, 3)
                }

    if result.tables:
        for t_idx, table in enumerate(result.tables):
            headers, row_map = {}, {}
            page_num = 1
            for cell in table.cells:
                if cell.bounding_regions:
                    page_num = cell.bounding_regions[0].page_number
                if cell.row_index == 0:
                    headers[cell.column_index] = cell.content.strip()
                else:
                    r = cell.row_index
                    if r not in row_map:
                        row_map[r] = {}
                    col = headers.get(cell.column_index, f"col_{cell.column_index}")
                    row_map[r][col] = cell.content.strip()

            rows = [row_map[k] for k in sorted(row_map.keys())]
            output["tables"].append({
                "table_index": t_idx,
                "headers":     list(headers.values()),
                "rows":        rows,
                "page_number": page_num
            })

    return output

# ── DI-only extraction ────────────────────────────────────────────────────────

def extract_di_only(
    di_output: dict,
    charge_keywords: list,
    col_mapping: dict,
    di_field_mapping: dict   # user's custom DI field mapping for this vendor
) -> dict:
    """
    Extract structured data from DI output WITHOUT calling LLM.
    Uses keyword matching on header_fields + table rows.
    User can provide a custom DI field mapping to override defaults.
    """

    def find_header_value(standard_field: str):
        # Check user's custom DI mapping first
        custom_key = di_field_mapping.get(standard_field)
        if custom_key:
            # Look for exact key match
            for k, v in di_output["header_fields"].items():
                if k.lower() == custom_key.lower():
                    return v["value"]

        # Fall back to keyword hints
        hints = DI_FIELD_HINTS.get(standard_field, [])
        for k, v in di_output["header_fields"].items():
            if any(hint.lower() in k.lower() for hint in hints):
                return v["value"]
        return None

    extracted = {
        "supplier_name":    find_header_value("supplier_name"),
        "supplier_id":      find_header_value("supplier_id"),
        "supplier_address": find_header_value("supplier_address"),
        "invoice_number":   find_header_value("invoice_number"),
        "invoice_date":     find_header_value("invoice_date"),
        "customer_name":    find_header_value("customer_name"),
        "customer_address": find_header_value("customer_address"),
        "remit_to":         find_header_value("remit_to"),
        "shipper_address":  find_header_value("shipper_address"),
        "bill_to":          find_header_value("bill_to"),
        "origin":           find_header_value("origin"),
        "destination":      find_header_value("destination"),
        "subtotal":         find_header_value("subtotal"),
        "total_amount":     find_header_value("total_amount"),
        "line_items":       [],
        "charge_lines":     [],
        "unmapped_header_fields": {}
    }

    # Collect unmapped header fields
    mapped_keys = set()
    for std_field in DI_FIELD_HINTS:
        hints = DI_FIELD_HINTS.get(std_field, [])
        custom = di_field_mapping.get(std_field, "")
        for k in di_output["header_fields"]:
            if custom and k.lower() == custom.lower():
                mapped_keys.add(k)
            elif any(hint.lower() in k.lower() for hint in hints):
                mapped_keys.add(k)

    for k, v in di_output["header_fields"].items():
        if k not in mapped_keys:
            extracted["unmapped_header_fields"][k] = v["value"]

    # Table rows
    # User can define column mapping for DI mode
    col_map = di_field_mapping.get("_columns", {})  # {"original col": "standard col"}

    for table in di_output.get("tables", []):
        page_num = table.get("page_number", 1)
        headers  = table.get("headers", [])

        # Detect which column maps to what
        def detect_col(role_hints):
            # custom override first
            for h in headers:
                if h in col_map and col_map[h] in role_hints:
                    return h
            # keyword match
            for h in headers:
                if any(hint.lower() in h.lower() for hint in role_hints):
                    return h
            return None

        col_item   = detect_col(["item", "item no", "item #", "sr no", "sl no", "line"])
        col_mfst   = detect_col(["manifest", "awb", "bol", "tracking", "bl no"])
        col_desc   = detect_col(["description", "particulars", "product", "item description",
                                  "service", "details", "goods"])
        col_qty    = detect_col(["qty", "quantity", "nos", "units", "count", "pcs"])
        col_uom    = detect_col(["uom", "unit", "uom", "measure", "ea", "kg", "cbm"])
        col_rate   = detect_col(["rate", "unit price", "unit cost", "price", "cost"])
        col_amount = detect_col(["amount", "total", "line total", "net amount", "value",
                                  "ext", "extended"])

        # All other columns = extra
        standard_cols = {col_item, col_mfst, col_desc, col_qty, col_uom, col_rate, col_amount}
        extra_cols    = [h for h in headers if h not in standard_cols and h is not None]

        for row in table.get("rows", []):
            desc_val = row.get(col_desc, "") if col_desc else ""

            # Detect if this is a charge row
            row_text = " ".join(str(v) for v in row.values()).lower()
            if is_charge_row(row_text, charge_keywords):
                # Find the amount value — last numeric-looking value
                amt_val = row.get(col_amount) if col_amount else None
                if amt_val is None:
                    for v in reversed(list(row.values())):
                        if to_float(v) is not None:
                            amt_val = v
                            break
                extracted["charge_lines"].append({
                    "description": desc_val or row_text[:80],
                    "charge_type": "charge",
                    "amount":      amt_val,
                    "page_number": page_num
                })
            else:
                item = {
                    "page_number":         page_num,
                    "item_number":         row.get(col_item)   if col_item   else None,
                    "manifest":            row.get(col_mfst)   if col_mfst   else None,
                    "description":         row.get(col_desc)   if col_desc   else None,
                    "quantity":            row.get(col_qty)    if col_qty    else None,
                    "unit_of_measurement": row.get(col_uom)    if col_uom    else None,
                    "rate":                row.get(col_rate)   if col_rate   else None,
                    "amount":              row.get(col_amount) if col_amount else None,
                    "extra_columns":       {h: row.get(h) for h in extra_cols if row.get(h)}
                }
                extracted["line_items"].append(item)

    return extracted

# ── LLM extraction ────────────────────────────────────────────────────────────

def extract_with_llm(di_output: dict, charge_keywords: list) -> dict:
    prompt = f"""
You are an invoice data extraction assistant.

=== NUMBER RULES (ABSOLUTE) ===
- Copy ALL numeric values EXACTLY as they appear — do NOT fix, round, or change any number
- Do NOT calculate any missing number — return null if missing

=== EXTRACTION RULES ===
- Map fields by meaning regardless of label name
- supplier = vendor / seller / from / shipper
- customer = bill to / sold to / buyer / client
- remit_to = remittance address / pay to
- shipper_address = ship from address
- bill_to = billing address
- charge_keywords: {charge_keywords}
- Rows matching charge_keywords → charge_lines array
- Include page_number per row (default 1)
- Extra table columns not in standard structure → extra_columns dict per row
- Return ONLY valid JSON, no explanation

DI RAW OUTPUT:
{json.dumps(di_output, indent=2)}

Return EXACTLY:
{{
  "supplier_name": null, "supplier_id": null, "supplier_address": null,
  "invoice_number": null, "invoice_date": null,
  "customer_name": null, "customer_address": null,
  "remit_to": null, "shipper_address": null, "bill_to": null,
  "origin": null, "destination": null,
  "subtotal": null, "total_amount": null,
  "line_items": [{{
    "page_number": 1, "item_number": null, "manifest": null,
    "description": null, "quantity": null, "unit_of_measurement": null,
    "rate": null, "amount": null, "extra_columns": {{}}
  }}],
  "charge_lines": [{{
    "description": null, "charge_type": null, "amount": null, "page_number": null
  }}],
  "unmapped_header_fields": {{}}
}}
"""

    response = get_llm_client().chat.completions.create(
        model=AZURE_OPENAI_DEPLOYMENT,
        messages=[
            {"role": "system", "content": "Extract invoice data. Never modify numbers. Return only valid JSON."},
            {"role": "user",   "content": prompt}
        ],
        max_tokens=3000,
        temperature=0
    )
    raw = re.sub(r"```json|```", "", response.choices[0].message.content.strip()).strip()
    return json.loads(raw)

# ── Build flat rows ───────────────────────────────────────────────────────────

def build_tabular_rows(filename: str, extracted: dict, mode: str) -> list:
    rows = []

    header = {
        "file_name":        filename,
        "extraction_mode":  mode,
        "supplier_name":    extracted.get("supplier_name"),
        "supplier_id":      extracted.get("supplier_id"),
        "supplier_address": extracted.get("supplier_address"),
        "invoice_number":   extracted.get("invoice_number"),
        "invoice_date":     extracted.get("invoice_date"),
        "customer_name":    extracted.get("customer_name"),
        "customer_address": extracted.get("customer_address"),
        "remit_to":         extracted.get("remit_to"),
        "shipper_address":  extracted.get("shipper_address"),
        "bill_to":          extracted.get("bill_to"),
        "origin":           extracted.get("origin"),
        "destination":      extracted.get("destination"),
    }

    for item in (extracted.get("line_items") or []):
        row = dict(header)
        row.update({
            "page_number":         item.get("page_number", 1),
            "item_number":         item.get("item_number"),
            "manifest":            item.get("manifest"),
            "description":         item.get("description"),
            "quantity":            item.get("quantity"),
            "unit_of_measurement": item.get("unit_of_measurement"),
            "rate":                item.get("rate"),
            "amount":              item.get("amount"),
            "subtotal":            None,
            "total":               None,
            "row_type":            "line_item"
        })
        for k, v in (item.get("extra_columns") or {}).items():
            row[k] = v
        rows.append(row)

    for charge in (extracted.get("charge_lines") or []):
        row = dict(header)
        row.update({
            "page_number":         charge.get("page_number", ""),
            "item_number":         None, "manifest": None,
            "description":         charge.get("description"),
            "quantity":            None, "unit_of_measurement": None,
            "rate":                None,
            "amount":              charge.get("amount"),
            "subtotal":            None, "total": None,
            "row_type":            f"charge:{charge.get('charge_type','other')}"
        })
        rows.append(row)

    if extracted.get("subtotal"):
        row = dict(header)
        row.update({
            "page_number": "", "item_number": None, "manifest": None,
            "description": "SUBTOTAL", "quantity": None,
            "unit_of_measurement": None, "rate": None, "amount": None,
            "subtotal": extracted.get("subtotal"), "total": None,
            "row_type": "subtotal"
        })
        rows.append(row)

    if extracted.get("total_amount"):
        row = dict(header)
        row.update({
            "page_number": "", "item_number": None, "manifest": None,
            "description": "TOTAL", "quantity": None,
            "unit_of_measurement": None, "rate": None, "amount": None,
            "subtotal": None, "total": extracted.get("total_amount"),
            "row_type": "total"
        })
        rows.append(row)

    return rows

# ── QC ────────────────────────────────────────────────────────────────────────

def run_qc(rows: list, extracted: dict) -> dict:
    issues     = {}
    total_amount = to_float(extracted.get("total_amount"))
    line_sum   = 0.0

    for i, row in enumerate(rows):
        if row.get("row_type") in ("subtotal", "total"):
            continue
        amt = to_float(row.get("amount"))
        if amt is not None:
            line_sum += amt

        qty  = to_float(row.get("quantity"))
        rate = to_float(row.get("rate"))
        if qty is not None and rate is not None and amt is not None:
            expected = round(qty * rate, 2)
            if abs(expected - round(amt, 2)) > 0.02:
                issues[i] = f"Qty×Rate={qty}×{rate}={expected} ≠ amount={amt}"

    total_issue = None
    if total_amount and abs(line_sum - total_amount) > 0.5:
        total_issue = f"Sum of amounts ({line_sum:.2f}) ≠ invoice total ({total_amount:.2f})"

    return {"row_issues": issues, "total_issue": total_issue, "line_sum": line_sum}

