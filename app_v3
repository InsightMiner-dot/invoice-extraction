def load_registry():
    if os.path.exists(REGISTRY_FILE):
        with open(REGISTRY_FILE, "r") as f:
            return json.load(f)
    return {}

def save_registry(registry):
    with open(REGISTRY_FILE, "w") as f:
        json.dump(registry, f, indent=2)

def looks_numeric_field(field_name: str) -> bool:
    numeric_keywords = [
        "amount", "total", "subtotal", "price", "rate", "cost",
        "qty", "quantity", "tax", "gst", "cgst", "sgst", "igst",
        "vat", "freight", "charge", "fee", "discount", "value",
        "number", "no", "#", "invoice no", "po no"
    ]
    return any(kw in field_name.lower() for kw in numeric_keywords)

def is_value_numeric(value: str) -> bool:
    if not value:
        return False
    cleaned = re.sub(r"[,.\s\-\+\%]", "", str(value))
    return bool(re.match(r"^\d+$", cleaned))

def has_suspect_ocr_chars(value: str) -> list:
    if not value:
        return []
    return [c for c in OCR_SUSPECT_CHARS if c in str(value)]

def flag_suspicious_numbers(di_output: dict) -> list:
    """
    Scan all DI extracted fields.
    Flag numeric-looking fields that contain OCR suspect characters.
    These MUST go to human review — LLM is not allowed to fix them.
    """
    suspicious = []

    for field_name, field_data in di_output.get("header_fields", {}).items():
        value = str(field_data.get("value") or "")
        if looks_numeric_field(field_name) or is_value_numeric(value):
            suspects = has_suspect_ocr_chars(value)
            if suspects:
                suspicious.append({
                    "location":   "header",
                    "field":      field_name,
                    "value":      value,
                    "suspects":   suspects,
                    "confidence": field_data.get("confidence", 0),
                    "corrected":  None
                })

    for t_idx, table in enumerate(di_output.get("tables", [])):
        for r_idx, row in enumerate(table.get("rows", [])):
            for col_name, value in row.items():
                value = str(value or "")
                if looks_numeric_field(col_name) or is_value_numeric(value):
                    suspects = has_suspect_ocr_chars(value)
                    if suspects:
                        suspicious.append({
                            "location":   f"table[{t_idx}].row[{r_idx}]",
                            "field":      col_name,
                            "value":      value,
                            "suspects":   suspects,
                            "confidence": 0,
                            "corrected":  None
                        })

        for r_idx, row in enumerate(table.get("charge_rows", [])):
            for col_name, value in row.items():
                value = str(value or "")
                if is_value_numeric(value):
                    suspects = has_suspect_ocr_chars(value)
                    if suspects:
                        suspicious.append({
                            "location":   f"table[{t_idx}].charge[{r_idx}]",
                            "field":      col_name,
                            "value":      value,
                            "suspects":   suspects,
                            "confidence": 0,
                            "corrected":  None
                        })

    return suspicious

def guard_numbers(di_output: dict, llm_output: dict) -> tuple:
    """
    After LLM runs — verify every numeric field was not changed.
    If LLM modified ANY number → revert to DI value.
    Returns (guarded_output, list_of_reverted_fields)
    """
    reverted = []

    def normalize(v):
        return re.sub(r"[,\s]", "", str(v or "")).strip().lower()

    NUMERIC_FIELD_KEYWORDS = {
        "invoice_number": ["invoice no", "invoice number", "inv no", "inv #"],
        "po_number":      ["po number", "po no", "purchase order", "order no"],
        "subtotal":       ["subtotal", "sub total", "net amount", "net total"],
        "tax_amount":     ["tax amount", "tax", "gst amount", "vat amount"],
        "total_amount":   ["total", "grand total", "invoice total", "amount due"],
    }

    di_values = {}
    for std_field, keywords in NUMERIC_FIELD_KEYWORDS.items():
        for di_key, di_data in di_output.get("header_fields", {}).items():
            if any(kw in di_key.lower() for kw in keywords):
                di_values[std_field] = di_data.get("value")
                break

    for field in NUMERIC_STANDARD_FIELDS:
        di_val  = di_values.get(field)
        llm_val = llm_output.get(field)
        if di_val and llm_val:
            if normalize(di_val) != normalize(str(llm_val)):
                reverted.append({
                    "field":     field,
                    "di_value":  di_val,
                    "llm_value": llm_val,
                    "action":    "reverted to DI value"
                })
                llm_output[field] = di_val

    di_rows  = di_output["tables"][0].get("rows", []) if di_output.get("tables") else []
    llm_rows = llm_output.get("line_items", [])

    for i, llm_row in enumerate(llm_rows):
        if i >= len(di_rows):
            break
        di_row = di_rows[i]
        di_numeric_vals = {
            normalize(v): v
            for k, v in di_row.items()
            if is_value_numeric(str(v))
        }
        for llm_col in LINE_ITEM_NUMERIC_COLS:
            llm_val = llm_row.get(llm_col)
            if not llm_val:
                continue
            if normalize(str(llm_val)) not in di_numeric_vals:
                # LLM invented or changed a number — find closest DI value
                for di_col, di_val in di_row.items():
                    if looks_numeric_field(di_col) and is_value_numeric(str(di_val)):
                        reverted.append({
                            "field":     f"line_item[{i}].{llm_col}",
                            "di_value":  di_val,
                            "llm_value": llm_val,
                            "action":    "reverted to DI value"
                        })
                        llm_row[llm_col] = di_val
                        break

    return llm_output, reverted

def validate_invoice(data: dict) -> list:
    errors = []
    try:
        def to_float(v):
            if not v:
                return 0.0
            return float(re.sub(r"[^\d.\-]", "", str(v)) or 0)

        subtotal  = to_float(data.get("subtotal"))
        total     = to_float(data.get("total_amount"))
        charges   = sum(
            to_float(c.get("charge_value"))
            for c in (data.get("total_level_charges") or [])
            if c.get("charge_type") not in ["discount", "rebate"]
        )
        discounts = sum(
            to_float(c.get("charge_value"))
            for c in (data.get("total_level_charges") or [])
            if c.get("charge_type") in ["discount", "rebate"]
        )
        if subtotal > 0 and total > 0:
            expected = subtotal + charges - discounts
            if abs(expected - total) > 1.0:
                errors.append(
                    f"Amount mismatch: {subtotal} + {charges:.2f} charges "
                    f"- {discounts:.2f} discounts = {expected:.2f}, but total = {total}"
                )
    except Exception as e:
        errors.append(f"Validation error: {e}")

    for field in ["invoice_number", "total_amount"]:
        if not data.get(field):
            errors.append(f"Missing required field: {field}")

    return errors

def is_scanned_pdf(file_bytes: bytes) -> bool:
    try:
        import fitz
        doc  = fitz.open(stream=file_bytes, filetype="pdf")
        text = "".join(page.get_text() for page in doc)
        return len(text.strip()) < 100
    except Exception:
        return False

def scan_quality_label(avg_conf: float) -> tuple:
    if avg_conf >= 0.85:
        return "🟢 Good", "Auto process"
    elif avg_conf >= 0.65:
        return "🟡 Fair", "LLM review recommended"
    else:
        return "🔴 Poor", "Human review required"

# ── Azure DI ──────────────────────────────────────────────────────────────────

def run_azure_di(file_bytes: bytes) -> dict:
    client = DocumentIntelligenceClient(DI_ENDPOINT, AzureKeyCredential(DI_KEY))
    poller = client.begin_analyze_document(
        "prebuilt-layout",
        body=file_bytes,
        content_type="application/octet-stream"
    )
    result = poller.result()

    output = {
        "raw_text":      result.content or "",
        "header_fields": {},
        "tables":        [],
        "charge_lines":  []
    }

    if result.key_value_pairs:
        for kv in result.key_value_pairs:
            if kv.key and kv.value:
                key   = kv.key.content.strip()
                value = kv.value.content.strip()
                output["header_fields"][key] = {
                    "value":      value,
                    "confidence": round(kv.confidence or 0, 3)
                }

    if result.tables:
        for t_idx, table in enumerate(result.tables):
            headers = {}
            for cell in table.cells:
                if cell.row_index == 0:
                    headers[cell.column_index] = cell.content.strip()

            row_map = {}
            for cell in table.cells:
                if cell.row_index == 0:
                    continue
                r = cell.row_index
                if r not in row_map:
                    row_map[r] = {}
                col_name = headers.get(cell.column_index, f"col_{cell.column_index}")
                row_map[r][col_name] = cell.content.strip()

            rows = [row_map[k] for k in sorted(row_map.keys())]

            item_rows, charge_rows = [], []
            for row in rows:
                row_text    = " ".join(str(v) for v in row.values()).lower()
                is_charge   = any(kw in row_text for kw in CHARGE_KEYWORDS)
                qty_present = any(
                    k.lower() in ["qty", "quantity", "nos", "units", "count"]
                    for k in row.keys()
                )
                if is_charge and not qty_present:
                    charge_rows.append(row)
                else:
                    item_rows.append(row)

            output["tables"].append({
                "table_index": t_idx,
                "headers":     list(headers.values()),
                "rows":        item_rows,
                "charge_rows": charge_rows
            })
            output["charge_lines"].extend(charge_rows)

    return output

# ── LLM — strict number protection prompt ────────────────────────────────────

def normalize_with_llm(di_output: dict) -> dict:
    client = get_llm_client()

    prompt = f"""
You are an invoice field mapping assistant.

Below is raw JSON from Azure Document Intelligence OCR.

=== ABSOLUTE RULES FOR NUMBERS — NO EXCEPTIONS ===

1. Copy ALL numeric values EXACTLY character-by-character as in DI output.
   This includes: amounts, totals, subtotals, quantities, prices,
   tax values, rates, invoice numbers, PO numbers, HSN codes.

2. Do NOT fix, correct, round, reformat, or change ANY number in any way.
   Even if a number looks wrong (e.g. "1,5O0.00") — return it EXACTLY as-is.

3. Do NOT remove or add commas, dots, spaces, or any character in numbers.

4. Do NOT calculate or derive any number:
   - Never compute subtotal from line items
   - Never compute tax from a rate
   - Never compute total from subtotal + charges
   - If a number is missing → return null. Never compute it.

5. For total_level_charges: extract charge values EXACTLY as they appear.
   Never calculate or infer a charge value.

=== RULES FOR TEXT FIELDS ONLY ===

6. You MAY clean obvious spelling in: vendor name, address, description,
   payment terms, field labels.

7. Dates: you may reformat ONLY the date format, never the date value.
   e.g. "15 Jan 2024" → "2024-01-15" is acceptable.
   But "15 Jan 2O24" → return "15 Jan 2O24" exactly (number rule applies).

8. Map original field names to standard structure based on meaning.

9. Return ONLY valid JSON. No explanation. No markdown.

DI RAW OUTPUT:
{json.dumps(di_output, indent=2)}

Return EXACTLY this JSON structure (use null for missing fields):
{{
    "invoice_number":  null,
    "invoice_date":    null,
    "due_date":        null,
    "po_number":       null,
    "payment_terms":   null,
    "currency":        null,
    "supplier": {{
        "name": null, "address": null, "tax_id": null
    }},
    "bill_to": {{
        "name": null, "address": null
    }},
    "ship_to": {{
        "name": null, "address": null
    }},
    "origin":      null,
    "destination": null,
    "line_items": [
        {{
            "description": null,
            "hsn_code":    null,
            "quantity":    null,
            "unit_price":  null,
            "tax_rate":    null,
            "total":       null
        }}
    ],
    "total_level_charges": [
        {{
            "charge_name":  null,
            "charge_value": null,
            "charge_type":  "tax|freight|handling|shipping|tsp|gst|cgst|sgst|igst|vat|discount|other"
        }}
    ],
    "subtotal":     null,
    "tax_amount":   null,
    "total_amount": null,
    "field_mappings":  {{}},
    "unmapped_fields": {{}}
}}
"""

    response = client.chat.completions.create(
        model=AZURE_OPENAI_DEPLOYMENT,   # deployment name, not model name
        messages=[
            {
                "role": "system",
                "content": (
                    "You map invoice fields. "
                    "CRITICAL: Never modify any numeric value. "
                    "Return only valid JSON."
                )
            },
            {"role": "user", "content": prompt}
        ],
        max_tokens=2000,
        temperature=0
    )

    raw = response.choices[0].message.content.strip()
    raw = re.sub(r"```json|```", "", raw).strip()
    return json.loads(raw)

def apply_vendor_config(di_output: dict, config: dict) -> dict:
    result = {"line_items": [], "total_level_charges": [], "unmapped_fields": {}}

    def set_nested(d, path, value):
        keys = path.split(".")
        for k in keys[:-1]:
            d = d.setdefault(k, {})
        d[keys[-1]] = value

    for original, field_data in di_output["header_fields"].items():
        if original in config.get("ignored_fields", []):
            continue
        value = config.get("overrides", {}).get(original) or field_data["value"]
        if original in config.get("header_mappings", {}):
            set_nested(result, config["header_mappings"][original], value)
        else:
            result["unmapped_fields"][original] = value

    if di_output.get("tables"):
        for row in di_output["tables"][0].get("rows", []):
            mapped_row = {}
            for col, value in row.items():
                if col in config.get("ignored_fields", []):
                    continue
                if col in config.get("column_mappings", {}):
                    mapped_row[config["column_mappings"][col]] = value
                else:
                    mapped_row[col] = value
            result["line_items"].append(mapped_row)

        for row in di_output["tables"][0].get("charge_rows", []):
            vals = list(row.values())
            result["total_level_charges"].append({
                "charge_name":  vals[0]  if vals else "",
                "charge_value": vals[-1] if vals else "",
                "charge_type":  "other"
            })

    return result

