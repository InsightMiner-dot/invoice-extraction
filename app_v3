        for k, v in di["header_fields"].items():
            conf = v["confidence"]
            icon = "🟢" if conf >= 0.85 else "🟡" if conf >= 0.65 else "🔴"
            suspects = has_suspect_ocr_chars(str(v["value"] or ""))
            rows.append({
                "Field":      k,
                "Value":      v["value"],
                "Confidence": f"{icon} {conf*100:.0f}%",
                "⚠️ OCR Suspect": "⚠️ " + " ".join(suspects) if suspects else ""
            })
        st.dataframe(pd.DataFrame(rows), use_container_width=True)

        if di["tables"]:
            st.markdown("### Line Item Table (original headers)")
            st.dataframe(pd.DataFrame(di["tables"][0]["rows"]), use_container_width=True)

            charge_rows = di["tables"][0].get("charge_rows", [])
            if charge_rows:
                st.markdown("### Detected Charge Rows")
                st.dataframe(pd.DataFrame(charge_rows), use_container_width=True)

        st.markdown("### Raw OCR Text")
        st.text_area("", di["raw_text"], height=200)

        with st.expander("Full DI JSON"):
            st.json(di)

# ════════════════════════════════════════════════════════
# TAB 3 — Number Review
# ════════════════════════════════════════════════════════
with tab3:
    st.subheader("🔢 Number Review — Human Correction")
    st.markdown("""
> **Why this tab exists:**
> OCR commonly confuses `O` with `0`, `l` with `1`, `I` with `1`, etc.
> **LLM is strictly prohibited from fixing any number.**
> You must enter the correct value by reading the original invoice.
""")

    suspicious = st.session_state.suspicious
    reverted   = st.session_state.reverted

    if not st.session_state.di_output:
        st.info("Run Azure DI first (Tab 1)")

    elif not suspicious:
        st.success("✅ No suspicious numeric fields detected — numbers look clean!")

    else:
        st.error(f"🔴 {len(suspicious)} numeric fields need human correction")
        st.markdown("---")

        corrections = dict(st.session_state.human_corrections)

        for i, item in enumerate(suspicious):
            key_id = f"{item['location']}.{item['field']}"

            st.markdown(f"**Field {i+1} of {len(suspicious)}**")
            r1, r2, r3, r4 = st.columns([2, 2, 3, 3])

            r1.markdown(f"📍 Location")
            r1.code(item["location"])

            r2.markdown(f"🏷️ Field Name")
            r2.code(item["field"])

            r3.markdown("🔴 DI Extracted (may have OCR error)")
            r3.error(item["value"])
            r3.caption(f"Suspect chars: `{'`, `'.join(item['suspects'])}`")

            r4.markdown("✏️ Correct Value (read from invoice)")
            correct = r4.text_input(
                "",
                value=corrections.get(key_id, ""),
                key=f"numfix_{i}",
                placeholder="Type exact value from invoice"
            )
            if correct:
                corrections[key_id] = correct

            st.markdown("---")

        if st.button("💾 Save All Number Corrections", type="primary", use_container_width=True):
            st.session_state.human_corrections = corrections
            saved = len([v for v in corrections.values() if v])
            st.success(f"✅ {saved} corrections saved — proceed to Tab 4")

    # Number guard report
    if reverted:
        st.divider()
        st.markdown("### 🛡️ Number Guard Report")
        st.caption("LLM attempted to change these — automatically reverted to DI values")
        st.dataframe(pd.DataFrame(reverted), use_container_width=True)

    # Preview current numeric values
    if st.session_state.llm_output:
        st.divider()
        st.markdown("### Current Numeric Values in Output")
        llm = st.session_state.llm_output
        for field in NUMERIC_STANDARD_FIELDS:
            val = llm.get(field)
            c1, c2 = st.columns([3, 4])
            c1.markdown(f"`{field}`")
            if val:
                suspects = has_suspect_ocr_chars(str(val))
                if suspects:
                    c2.error(f"{val}  ⚠️ Still suspect: {''.join(suspects)} — correct above")
                else:
                    c2.success(f"{val} ✅")
            else:
                c2.warning("null")

# ════════════════════════════════════════════════════════
# TAB 4 — Configure Mapping
# ════════════════════════════════════════════════════════
with tab4:
    st.subheader("Configure Field Mapping")

    if not st.session_state.llm_output:
        st.info("Complete Steps 1 & 2 in Tab 1 first")
    else:
        llm = st.session_state.llm_output
        di  = st.session_state.di_output

        vendor_name = st.text_input(
            "Vendor Name (saved as registry key)",
            value=st.session_state.vendor_name
        )
        st.session_state.vendor_name = vendor_name

        if st.session_state.suspicious and not st.session_state.human_corrections:
            st.warning("⚠️ You have unresolved suspicious numbers — complete Tab 3 first")

        # ── Header Fields ──────────────────────────────
        st.markdown("### Header Fields")
        st.caption("🔒 = numeric field (LLM cannot modify) | 🟢🟡🔴 = DI confidence")

        header_config  = {}
        field_mappings = llm.get("field_mappings", {})
        all_header_keys = list(di["header_fields"].keys())
        for k in (llm.get("unmapped_fields") or {}):
            if k not in all_header_keys:
                all_header_keys.append(k)

        if all_header_keys:
            hc = st.columns([0.5, 2, 2.5, 2, 2])
            hc[0].markdown("**Keep**")
            hc[1].markdown("**Field**")
            hc[2].markdown("**DI Value**")
            hc[3].markdown("**Map To**")
            hc[4].markdown("**Override / Fix**")

            for key in all_header_keys:
                fd         = di["header_fields"].get(key, {})
                di_val     = fd.get("value", (llm.get("unmapped_fields") or {}).get(key, ""))
                conf       = fd.get("confidence", 1.0)
                suggested  = field_mappings.get(key, "")
                is_num     = looks_numeric_field(key) or is_value_numeric(str(di_val or ""))
                suspects   = has_suspect_ocr_chars(str(di_val or ""))
                icon       = "🟢" if conf >= 0.85 else "🟡" if conf >= 0.65 else "🔴"
                lock       = " 🔒" if is_num else ""

                c = st.columns([0.5, 2, 2.5, 2, 2])
                keep = c[0].checkbox("", value=bool(suggested), key=f"hk_{key}")
                c[1].markdown(f"`{key}`{lock}")

                val_disp = f"{icon} `{di_val}`"
                if suspects:
                    val_disp += f" ⚠️`{''.join(suspects)}`"
                c[2].markdown(val_disp)

                mapped_to = c[3].selectbox(
                    "",
                    [""] + ALL_STANDARD_FIELDS,
                    index=ALL_STANDARD_FIELDS.index(suggested) + 1
                    if suggested in ALL_STANDARD_FIELDS else 0,
                    key=f"hm_{key}",
                    disabled=not keep
                )

                hint = "⚠️ Paste corrected value" if suspects else "Optional override"
                override = c[4].text_input(
                    "", placeholder=hint, key=f"ho_{key}", disabled=not keep
                )

                if keep:
                    header_config[key] = {"mapped_to": mapped_to, "override": override}

        st.session_state.header_config = header_config

        # ── Table Columns ──────────────────────────────
        st.markdown("### Table Columns")
        st.caption("🔒 numeric columns — DI values used directly")

        column_config = {}
        table_headers = di["tables"][0]["headers"] if di and di["tables"] else []
        sample_row    = di["tables"][0]["rows"][0]  if di and di["tables"] and di["tables"][0]["rows"] else {}

        if table_headers:
            tc = st.columns([0.5, 2, 2, 2])
            tc[0].markdown("**Keep**")
            tc[1].markdown("**Column**")
            tc[2].markdown("**Sample**")
            tc[3].markdown("**Map To**")

            for col_name in table_headers:
                sv       = str(sample_row.get(col_name, ""))
                is_num   = looks_numeric_field(col_name) or is_value_numeric(sv)
                suspects = has_suspect_ocr_chars(sv)
                lock     = " 🔒" if is_num else ""

                c = st.columns([0.5, 2, 2, 2])
                keep = c[0].checkbox("", value=True, key=f"ck_{col_name}")
                c[1].markdown(f"`{col_name}`{lock}")

                sv_disp = f"`{sv}`"
                if suspects:
                    sv_disp += f" ⚠️`{''.join(suspects)}`"
                c[2].markdown(sv_disp)

                mapped_to = c[3].selectbox(
                    "", [""] + LINE_ITEM_ALL_COLS + ["ignore"],
                    key=f"cm_{col_name}", disabled=not keep
                )
                if keep:
                    column_config[col_name] = mapped_to

        st.session_state.column_config = column_config

        # ── Total Level Charges ────────────────────────
        st.markdown("### Total Level Charges")
        st.caption("🔒 Charge values are from DI — edit only if you see a clear OCR error")

        charges      = llm.get("total_level_charges") or []
        charges_data = []

        if charges:
            for i, charge in enumerate(charges):
                c1, c2, c3, c4 = st.columns([2, 2, 2, 0.7])
                name  = c1.text_input("Name",     value=charge.get("charge_name", ""),  key=f"cn_{i}")
                value = c2.text_input("Value 🔒", value=charge.get("charge_value", ""), key=f"cv_{i}",
                                      help="From DI — only edit if clear OCR error")
                ctype = c3.selectbox(
                    "Type",
                    ["tax","freight","handling","shipping","tsp","gst",
                     "cgst","sgst","igst","vat","discount","other"],
                    key=f"ct_{i}"
                )
                keep = c4.checkbox("✅", value=True, key=f"ckeep_{i}")
                if keep:
                    charges_data.append({
                        "charge_name":  name,
                        "charge_value": value,
                        "charge_type":  ctype
                    })
        else:
            st.info("No charges detected — add manually below if present on invoice")

        st.markdown("**➕ Add charge manually:**")
        a1, a2, a3, a4 = st.columns([2, 2, 2, 1])
        nc_name  = a1.text_input("Name",     key="ncn", placeholder="e.g. Freight")
        nc_value = a2.text_input("Value 🔒", key="ncv", placeholder="e.g. 150.00",
                                 help="Enter exact value from invoice")
        nc_type  = a3.selectbox(
            "Type",
            ["tax","freight","handling","shipping","tsp","gst",
             "cgst","sgst","igst","vat","discount","other"],
            key="nct"
        )
        if a4.button("Add ➕"):
            if nc_name and nc_value:
                charges_data.append({
                    "charge_name": nc_name, "charge_value": nc_value, "charge_type": nc_type
                })
                st.success(f"Added: {nc_name} = {nc_value}")

        # ── Save ───────────────────────────────────────
        st.divider()
        if st.button("💾 Save Config & Build Final Output", type="primary", use_container_width=True):
            if not vendor_name:
                st.error("Enter a vendor name")
            else:
                header_mappings, ignored_fields, overrides = {}, [], {}
                for k, v in st.session_state.header_config.items():
                    mt = v.get("mapped_to", "")
                    if mt and mt != "ignore":
                        header_mappings[k] = mt
                    else:
                        ignored_fields.append(k)
                    if v.get("override"):
                        overrides[k] = v["override"]

                column_mappings = {}
                for k, v in st.session_state.column_config.items():
                    if v and v != "ignore":
                        column_mappings[k] = v
                    else:
                        ignored_fields.append(k)

                config = {
                    "vendor_name":     vendor_name,
                    "header_mappings": header_mappings,
                    "column_mappings": column_mappings,
                    "ignored_fields":  ignored_fields,
                    "overrides":       overrides,
                    "updated_at":      datetime.utcnow().isoformat()
                }
                registry = load_registry()
                registry[vendor_name] = config
                save_registry(registry)

                # Build final output
                final = json.loads(json.dumps(llm))  # deep copy
                final["total_level_charges"] = charges_data

                # Apply user overrides (header fields)
                for original_key, override_val in overrides.items():
                    if original_key in header_mappings:
                        target = header_mappings[original_key]
                        keys   = target.split(".")
                        d      = final
                        for k in keys[:-1]:
                            d = d.setdefault(k, {})
                        d[keys[-1]] = override_val

                # Apply human number corrections from Tab 3
                corrections = st.session_state.human_corrections
                for loc_field, correct_val in corrections.items():
                    for num_field in NUMERIC_STANDARD_FIELDS:
                        if num_field in loc_field:
                            final[num_field] = correct_val
                            break

                # Final number guard pass
                final, reverted = guard_numbers(di, final)
                st.session_state.reverted = reverted

                errors = validate_invoice(final)
                final["_validation_errors"]  = errors
                final["_extraction_method"]  = "DI + LLM (numbers protected)"
                final["_number_corrections"] = corrections
                final["_reverted_fields"]    = reverted

                st.session_state.final_output = final
                st.success(f"✅ Config saved for '{vendor_name}' — check Tab 5 for result")

                if errors:
                    for e in errors:
                        st.warning(f"⚠️ {e}")
                else:
                    st.success("✅ Math validation passed!")

