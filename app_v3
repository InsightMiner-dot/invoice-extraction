            with st.expander(f"🗂️ Field Mapping — {fi['name']}", expanded=False):
                st.caption(
                    "Select the DI label that corresponds to each standard field. "
                    "Leave blank to use auto-detection."
                )
                file_mapping = {}
                col_mapping_table = {}

                # Header field mappings
                st.markdown("**Header Fields**")
                STANDARD_HEADER_FIELDS = [
                    "supplier_name", "supplier_id", "supplier_address",
                    "invoice_number", "invoice_date",
                    "customer_name", "customer_address",
                    "remit_to", "shipper_address", "bill_to",
                    "origin", "destination",
                    "subtotal", "total_amount"
                ]
                for std in STANDARD_HEADER_FIELDS:
                    c1, c2 = st.columns([2, 3])
                    c1.markdown(f"`{std}`")
                    selected = c2.selectbox(
                        "", di_labels,
                        key=f"di_hmap_{fi['name']}_{std}",
                        index=0
                    )
                    if selected:
                        file_mapping[std] = selected

                # Table column mappings
                if preview_key in st.session_state and st.session_state[preview_key].get("tables"):
                    st.markdown("**Table Columns**")
                    table_headers = [""] + st.session_state[preview_key]["tables"][0]["headers"]
                    LINE_STANDARD = [
                        "item_number", "manifest", "description",
                        "quantity", "unit_of_measurement", "rate", "amount"
                    ]
                    for std in LINE_STANDARD:
                        c1, c2 = st.columns([2, 3])
                        c1.markdown(f"`{std}`")
                        selected = c2.selectbox(
                            "", table_headers,
                            key=f"di_cmap_{fi['name']}_{std}",
                            index=0
                        )
                        if selected:
                            col_mapping_table[selected] = std

                file_mapping["_columns"] = col_mapping_table
                di_field_mappings[fi["name"]] = file_mapping

        st.session_state["di_field_mappings_tab2"] = di_field_mappings

        # ── Step 3: Process ────────────────────────────
        st.divider()
        st.markdown("### Step 3 — Extract")

        if st.button("⚡ Extract All DI-Only Files", type="primary", use_container_width=True):
            charge_keywords = st.session_state.charge_keywords
            progress = st.progress(0)
            errors   = []

            for idx, fi in enumerate(di_only_info):
                progress.progress((idx) / len(di_only_info), text=f"Processing {fi['name']}...")

                try:
                    # Run DI if not already done
                    preview_key = f"di_preview_{fi['name']}"
                    if preview_key not in st.session_state:
                        st.session_state[preview_key] = run_azure_di(fi["bytes"])

                    di_out       = st.session_state[preview_key]
                    file_di_map  = st.session_state.get("di_field_mappings_tab2", {}).get(fi["name"], {})

                    extracted = extract_di_only(di_out, charge_keywords, {}, file_di_map)
                    rows      = build_tabular_rows(fi["name"], extracted, "DI Only")
                    qc        = run_qc(rows, extracted)

                    st.session_state.all_extracted[fi["name"]] = extracted
                    st.session_state.all_rows.extend(rows)
                    st.session_state.qc_results[fi["name"]]  = qc
                    st.session_state.processed_files.add(fi["name"])

                    st.success(f"✅ {fi['name']} — {len(rows)} rows")

                except Exception as e:
                    errors.append(f"{fi['name']}: {e}")
                    st.error(f"❌ {fi['name']}: {e}")

            progress.progress(1.0, text="Done!")
            if not errors:
                st.success("All DI-only files processed → go to Tab 4 for results")

