        # ── Step 2: Column mapping per file ───────────
        st.divider()
        st.markdown("### Step 2 — Map DI Labels to Standard Fields (Optional)")
        st.caption(
            "If DI found the right fields with keyword matching, you can skip this. "
            "Only fill in fields where auto-detection might miss."
        )

        di_field_mappings = {}

        for fi in di_only_info:
            preview_key = f"di_preview_{fi['name']}"
            di_labels   = []
            if preview_key in st.session_state:
                di_labels = [""] + list(st.session_state[preview_key]["header_fields"].keys())
                # Add table headers too
                for t in st.session_state[preview_key].get("tables", []):
                    for h in t["headers"]:
